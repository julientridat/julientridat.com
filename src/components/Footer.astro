---
import Logo from "@/components/Logo.astro";

interface Props {
  home?: boolean;
}
const { home = false } = Astro.props;
const p = home ? "" : "/";
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 px-6 py-12 md:px-12">
  <div class="mx-auto flex max-w-7xl flex-col gap-6 md:flex-row md:items-center md:justify-between">
    <Logo href={home ? undefined : "/"} />
    <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/55">
      <a href={`${p}#methode`} class="hover:text-white">Méthode</a>
      <a href={`${p}#offres`} class="hover:text-white">Offres</a>
      <a href="/realisations" class="hover:text-white">Cas clients</a>
      <a href="/notes" class="hover:text-white">Notes</a>
      <a href={`${p}#references`} class="hover:text-white">Références</a>
      <a href={`${p}#about`} class="hover:text-white">À propos</a>
      <a href={`${p}#contact`} class="hover:text-white">Contact</a>
    </div>
    <div class="text-xs text-white/40">© {year} Julien Tridat — Bordeaux</div>
  </div>
</footer>
