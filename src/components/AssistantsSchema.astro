---
interface Assistant {
  nom: string;
  entree: string;
  sortie: string;
  fait?: string;
}
interface Props {
  assistants: Assistant[];
}
const { assistants } = Astro.props;
---

<div class="space-y-4">
  {assistants.map((a) => (
    <div class="rounded-2xl border border-white/12 bg-white/[0.02] p-6">
      <div class="grid items-stretch gap-3 md:grid-cols-[1fr_auto_1.4fr_auto_1fr]">
        <!-- entrée -->
        <div class="flex flex-col justify-center rounded-xl border border-dashed border-white/15 px-4 py-3 text-center">
          <div class="text-[10px] uppercase tracking-[0.18em] text-white/40">Entrée</div>
          <div class="mt-1 text-[13px] leading-snug text-white/75">{a.entree}</div>
        </div>
        <div class="hidden items-center justify-center text-lime md:flex" aria-hidden="true">→</div>
        <!-- l'assistant -->
        <div class="flex flex-col justify-center rounded-xl border border-lime/40 bg-lime/[0.06] px-4 py-4 text-center">
          <div class="text-[10px] uppercase tracking-[0.18em] text-lime/80">Assistant</div>
          <div class="mt-1 text-[15px] font-medium leading-snug text-white">{a.nom}</div>
        </div>
        <div class="hidden items-center justify-center text-lime md:flex" aria-hidden="true">→</div>
        <!-- sortie -->
        <div class="flex flex-col justify-center rounded-xl border border-white/15 bg-white/[0.04] px-4 py-3 text-center">
          <div class="text-[10px] uppercase tracking-[0.18em] text-white/40">Sortie</div>
          <div class="mt-1 text-[13px] leading-snug text-white/85">{a.sortie}</div>
        </div>
      </div>
      {a.fait && <p class="mt-4 border-t border-white/10 pt-3 text-[13px] leading-relaxed text-white/55">{a.fait}</p>}
    </div>
  ))}
</div>
