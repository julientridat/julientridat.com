---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"realisations">;
}
const { entry } = Astro.props;
const d = entry.data;
const chiffres = d.resultats.slice(0, 2);
---

<a
  href={`/realisations/${entry.id}`}
  class="group flex flex-col rounded-2xl border border-white/12 bg-white/[0.02] p-7 transition-colors hover:border-lime/60"
>
  <div class="text-[11px] uppercase tracking-[0.18em] text-white/55">{d.secteur}</div>
  <h3 class="mt-4 text-[19px] font-medium leading-snug tracking-[-0.01em]">{d.title}</h3>
  {d.transformation && (
    <p class="mt-3 line-clamp-3 text-[14px] leading-relaxed text-white/60">{d.transformation}</p>
  )}

  {chiffres.length > 0 && (
    <div class="mt-auto flex flex-wrap gap-x-8 gap-y-3 border-t border-white/10 pt-6">
      {chiffres.map((res) => (
        <div>
          <div class="text-2xl font-light text-lime">{res.chiffre}</div>
          <div class="mt-0.5 max-w-[11rem] text-[10.5px] uppercase tracking-wider text-white/55">
            {res.label}
          </div>
        </div>
      ))}
    </div>
  )}

  <div class="mt-6 inline-flex items-center gap-2 text-[13px] text-lime">
    Lire la transformation
    <span class="transition-transform group-hover:translate-x-0.5">→</span>
  </div>
</a>
