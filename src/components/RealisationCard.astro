---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"realisations">;
}
const { entry } = Astro.props;
const d = entry.data;
const chiffre = d.resultats[0];
---

<a
  href={`/realisations/${entry.id}`}
  class="group flex flex-col overflow-hidden rounded-2xl border border-white/12 bg-white/[0.02] transition-colors hover:border-lime/60"
>
  <div class="relative aspect-[16/9] overflow-hidden border-b border-white/10 bg-[oklch(0.16_0_0)]">
    {d.visuel ? (
      <img
        src={d.visuel.src}
        alt={d.visuel.alt}
        width="800"
        height="450"
        loading="lazy"
        class="h-full w-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.03]"
      />
    ) : (
      <div class="flex h-full flex-col justify-between p-6">
        <span class="text-[10px] uppercase tracking-[0.22em] text-white/35">{d.secteur}</span>
        {chiffre && (
          <div>
            <div class="text-5xl font-light text-lime/90">{chiffre.chiffre}</div>
            <div class="mt-1 max-w-[16rem] text-[11px] uppercase tracking-wider text-white/45">{chiffre.label}</div>
          </div>
        )}
      </div>
    )}
  </div>

  <div class="flex flex-1 flex-col p-6">
    <div class="truncate text-[11px] uppercase tracking-[0.18em] text-white/45">
      {d.client}
    </div>
    <h3 class="mt-2.5 line-clamp-2 text-[17px] font-medium leading-snug">{d.title}</h3>
    <p class="mt-2 line-clamp-2 text-[13.5px] leading-relaxed text-white/55">{d.pitch}</p>
    <div class="mt-auto flex items-center justify-between gap-4 pt-5">
      {chiffre ? (
        <span class="truncate text-[12px] text-white/50">
          <span class="font-medium text-lime">{chiffre.chiffre}</span>
          {" "}{chiffre.label}
        </span>
      ) : (
        <span />
      )}
      <span class="text-lime transition-transform group-hover:translate-x-0.5">→</span>
    </div>
  </div>
</a>
