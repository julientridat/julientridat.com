---
import CtaButton from "@/components/CtaButton.astro";
---

<section id="contact" class="relative overflow-hidden border-t border-white/10 px-6 py-32 md:px-12 md:py-40">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(700px 400px at 50% 0%, oklch(0.92 0.21 125 / 0.10), transparent 70%);"
  >
  </div>
  <div class="mx-auto max-w-4xl text-center">
    <div class="mb-6 text-[11px] uppercase tracking-[0.22em] text-lime">Prochaine étape</div>
    <h2 class="text-[clamp(2.2rem,5.5vw,4.5rem)] font-light leading-[1.02] tracking-[-0.03em]">
      30 minutes pour savoir <em class="text-lime">si c'est pour vous.</em>
    </h2>
    <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-white/70">
      Un échange direct. Pas un pitch. Je vous dis si mon offre colle à votre contexte.
      Si oui, on enchaîne sur l'audit. Si non, je vous oriente.
    </p>
    <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
      <CtaButton>Réserver un audit — 30 minutes</CtaButton>
      <a
        href="#offres"
        class="inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3.5 text-sm text-white/80 transition-colors hover:border-lime hover:text-lime"
      >
        Voir le détail des offres
      </a>
    </div>
  </div>
</section>
