---
import { getCollection } from "astro:content";
import Eyebrow from "@/components/Eyebrow.astro";
import RealisationCard from "@/components/RealisationCard.astro";

const realisations = (await getCollection("realisations", ({ data }) => data.published))
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder)
  .slice(0, 3);
---

<section id="registre" class="border-t border-white/10 px-6 py-24 md:px-12 md:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 md:grid-cols-2 md:items-end">
      <div>
        <Eyebrow>Cas clients</Eyebrow>
        <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-light leading-[1.05] tracking-[-0.03em]">
          Des entreprises
          <br />
          <em class="text-lime">transformées.</em>
        </h2>
      </div>
      <p class="max-w-md text-lg leading-relaxed text-white/75">
        À travers moi, chacune s'est dotée d'un moyen de production qu'elle n'avait pas.{" "}
        <strong class="font-medium text-white">L'enjeu, le système déployé, la transformation — vérifiables.</strong>
      </p>
    </div>

    <div class="mt-16 grid gap-5 md:grid-cols-3">
      {realisations.map((r) => <RealisationCard entry={r} />)}
    </div>

    <div class="mt-12 flex flex-wrap gap-x-10 gap-y-4">
      <a
        href="/realisations"
        class="inline-flex items-center gap-2 border-b border-lime pb-1 text-lg text-lime transition hover:gap-3"
      >
        → Tous les cas clients
      </a>
      <a
        href="/capacites"
        class="inline-flex items-center gap-2 border-b border-white/30 pb-1 text-lg text-white/80 transition hover:gap-3 hover:border-lime hover:text-lime"
      >
        → Les moyens de production que je déploie
      </a>
    </div>
  </div>
</section>
