---
import Eyebrow from "@/components/Eyebrow.astro";
import CtaButton from "@/components/CtaButton.astro";

const items = [
  ["01", "Rédaction commerciale", "Calibré sur votre charte, votre ton, vos cibles. Propositions, emails, fiches produit."],
  ["02", "Appels d'offres", "Analyse et réponse aux AO. Gagne des heures sur chaque dossier de candidature."],
  ["03", "Analyse CRM", "Comptes dormants, signaux faibles, opportunités. Votre pipeline parle enfin."],
  ["04", "Reporting & réunions", "Synthèse de réunion, compte-rendu structuré, dashboard narratif. En 2 minutes."],
  ["05", "RH & onboarding", "Fiches de poste, entretiens, parcours d'intégration. Le savoir-faire capturé dans l'outil."],
  ["06", "Assistant dirigeant", "Veille stratégique, synthèse d'information, aide à la décision. Votre copilote quotidien."],
  ["07", "Marketing & contenus", "Publications, fiches produit, campagnes. À l'image de votre marque, pas de ChatGPT générique."],
  ["08", "Support client", "SAV, qualification tickets, réponses standard. Vos équipes se concentrent sur ce qui compte."],
  ["09", "Facturation & relance", "Génération de devis, relances personnalisées, suivi des impayés. Automatisé, pas robotique."],
];
---

<section id="assistants" class="border-t border-white/10 bg-[oklch(0.17_0_0)] px-6 py-24 md:px-12 md:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 md:grid-cols-2 md:items-end">
      <div>
        <Eyebrow>Ce que je construis</Eyebrow>
        <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-light leading-[1.05] tracking-[-0.03em]">
          Des assistants <em class="text-lime">concrets.</em>
        </h2>
      </div>
      <p class="max-w-md text-lg leading-relaxed text-white/75">
        Pas de ChatGPT générique. Chaque assistant est calibré sur votre métier, votre charte,
        vos données. Voici les neuf cas d'usage les plus déployés.
      </p>
    </div>

    <div class="mt-16 grid gap-px overflow-hidden rounded-2xl bg-white/10 sm:grid-cols-2 lg:grid-cols-3">
      {items.map(([num, title, desc]) => (
        <div class="group relative bg-[oklch(0.17_0_0)] p-8 transition-colors hover:bg-[oklch(0.2_0_0)]">
          <div class="text-xs uppercase tracking-[0.22em] text-lime">{num}</div>
          <h3 class="mt-4 text-xl font-medium">{title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/70">{desc}</p>
        </div>
      ))}
      <div class="group relative bg-lime/10 p-8 transition-colors hover:bg-lime/15">
        <div class="text-xs uppercase tracking-[0.22em] text-lime">10</div>
        <h3 class="mt-4 text-xl font-medium">
          Un assistant manquant ?
          <br />
          <em class="not-italic text-lime">On le construit.</em>
        </h3>
        <p class="mt-3 text-sm leading-relaxed text-white/75">
          Chaque mission inclut 3 à 10 assistants sur mesure selon votre offre.
        </p>
        <div class="mt-6">
          <CtaButton variant="outline">Réserver un audit</CtaButton>
        </div>
      </div>
    </div>
  </div>
</section>
