---
import Eyebrow from "@/components/Eyebrow.astro";
import CtaButton from "@/components/CtaButton.astro";

const stages = [
  {
    num: "01",
    week: "Audit intégré",
    title: "On observe vos vraies journées.",
    desc: "J'observe vos processus, j'identifie les tâches à forte répétition et faible valeur ajoutée. Pas un diagnostic théorique — un relevé terrain.",
  },
  {
    num: "02",
    week: "Construction des assistants",
    title: "Directement dans vos outils.",
    desc: "Je construis les assistants IA directement dans vos outils. Calibrés sur votre métier, votre charte, vos données.",
  },
  {
    num: "03",
    week: "Déploiement par vague",
    title: "En production dès la semaine 3.",
    desc: "Les premiers assistants tournent en production dès la semaine 3 ou 4. Vous commencez à gagner du temps avant la fin du projet.",
  },
  {
    num: "04",
    week: "Formation métier",
    title: "Vos équipes deviennent autonomes.",
    desc: "Vos équipes apprennent à utiliser les assistants créés pour elles. 2 à 3 demi-journées. Pas de théorie IA — juste des cas d'usage réels.",
  },
];
---

<section id="methode" class="border-t border-white/10 px-6 py-24 md:px-12 md:py-32">
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-10 md:grid-cols-2 md:items-end">
      <div>
        <Eyebrow>La méthode</Eyebrow>
        <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-light leading-[1.05] tracking-[-0.03em]">
          4 étapes.
          <br />
          <em class="text-lime">Pas une de plus.</em>
        </h2>
      </div>
      <p class="max-w-md text-lg leading-relaxed text-white/75">
        Un cadre simple, testé auprès de 300+ dirigeants et cadres.{" "}
        <strong class="font-medium text-white">
          On installe, on construit, on déploie, on forme.
        </strong>
      </p>
    </div>

    <div class="relative mt-20">
      <div class="absolute left-0 right-0 top-6 hidden h-px bg-white/15 md:block"></div>
      <div class="grid gap-12 md:grid-cols-4">
        {stages.map((s) => (
          <div class="relative">
            <div class="mb-6 hidden h-3 w-3 rounded-full bg-lime md:-mt-7 md:block"></div>
            <div class="text-xs uppercase tracking-[0.22em] text-lime">{s.num}</div>
            <div class="mt-2 text-sm text-white/60">{s.week}</div>
            <h3 class="mt-4 text-xl font-medium leading-snug">{s.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-white/70">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-20 grid gap-8 border-t border-white/10 pt-10 md:grid-cols-[1fr_auto] md:items-center">
      <p class="max-w-2xl text-lg leading-relaxed text-white/80">
        À la fin des 8 semaines, chaque membre de votre équipe aura gagné{" "}
        <em class="text-lime">jusqu'à 10 heures par semaine</em> — sans stress et sans friction.
      </p>
      <CtaButton>Réserver un audit</CtaButton>
    </div>
  </div>
</section>
