---
import Logo from "@/components/Logo.astro";

interface Props {
  /** Sur la home, les ancres restent locales ; ailleurs, elles pointent vers /#…. */
  home?: boolean;
}
const { home = false } = Astro.props;
const p = home ? "" : "/";

const links = [
  { href: `${p}#offres`, label: "Offres", caret: true },
  { href: `${p}#methode`, label: "Méthode" },
  { href: "/realisations", label: "Cas clients" },
  { href: "/notes", label: "Notes" },
  { href: `${p}#about`, label: "À propos", caret: true },
];
---

<nav class="absolute inset-x-0 top-0 z-50 flex items-center justify-between px-6 py-6 md:px-12 md:py-8">
  <Logo href={home ? undefined : "/"} />
  <ul class="hidden items-center gap-10 text-[15px] text-white md:flex">
    {links.map((l) => (
      <li>
        <a href={l.href} class="inline-flex items-center gap-1 transition-opacity hover:opacity-75">
          {l.label}
          {l.caret && <span class="text-xs opacity-70">▾</span>}
        </a>
      </li>
    ))}
  </ul>
  <button
    type="button"
    data-open-contact
    class="cursor-pointer rounded-full bg-white px-5 py-2.5 text-[15px] font-medium text-black transition-colors hover:bg-white/90"
  >
    Contact
  </button>
</nav>
