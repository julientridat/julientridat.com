---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/site";

const title = "L'expérience — votre entreprise, étudiée par l'IA en direct | Julien Tridat";
const description =
  "Un parcours guidé : donnez l'adresse de votre site, je l'analyse et le mesure en direct, puis vous choisissez votre étude — concurrents, cibles idéales, nouvel axe marketing — rédigée pour votre entreprise, sous vos yeux.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "L'expérience — Julien Tridat",
    description,
    url: `${SITE.url}/experience`,
    author: { "@id": `${SITE.url}/#julien-tridat` },
  },
];

const QUIZ = [
  {
    q: "Votre équipe, c'est…",
    options: ["Moi, seul(e)", "2 à 10 personnes", "11 à 50 personnes", "Plus de 50"],
    cle: "Taille d'équipe",
  },
  {
    q: "Le temps part surtout dans…",
    options: ["Devis & propositions", "Relances & suivi client", "Administratif & saisie", "Contenus & communication"],
    cle: "Où part le temps",
  },
  {
    q: "Vos informations (clients, prix, documents) sont…",
    options: ["Dans ma tête", "Éparpillées (mails, Excel, papier)", "Centralisées dans un outil"],
    cle: "État des données",
  },
  {
    q: "L'IA, aujourd'hui, chez vous…",
    options: ["Jamais testée", "Testée, sans suite", "Utilisée de temps en temps", "Déjà dans nos process"],
    cle: "Usage actuel de l'IA",
  },
  {
    q: "Votre objectif n°1 :",
    options: ["Gagner du temps", "Vendre plus", "Réduire les erreurs", "Rendre l'équipe autonome"],
    cle: "Objectif prioritaire",
  },
];

---

<BaseLayout title={title} description={description} canonical={`${SITE.url}/experience`} jsonLd={jsonLd}>
  <main id="xp" class="flex h-[100svh] flex-col overflow-hidden bg-background text-foreground">
    <!-- ═════════ EN-TÊTE DU PARCOURS ═════════ -->
    <nav class="z-20 flex shrink-0 items-center justify-between gap-3 border-b border-white/8 px-5 py-4 md:px-10">
      <div class="flex items-center gap-3">
        <button type="button" id="xp-retour" class="hidden h-9 w-9 shrink-0 cursor-pointer rounded-full border border-white/15 text-white/60 transition-colors hover:border-lime hover:text-lime" aria-label="Étape précédente">←</button>
        <a href="/" class="flex items-center gap-3 text-[15px] font-medium tracking-tight">
          <span class="grid grid-cols-3 gap-[2px]" style="width:18px;height:18px" aria-hidden="true">
            {Array.from({ length: 9 }).map(() => <span class="block rounded-[2px] bg-lime" style="width:5px;height:5px" />)}
          </span>
          <span class="hidden sm:inline">Julien Tridat</span>
        </a>
      </div>
      <ol id="xp-progression" class="flex items-center gap-2 text-[10px] uppercase tracking-[0.18em] text-white/35 sm:gap-3 sm:text-[11px]" aria-label="Progression du parcours">
        {["votre site", "lecture", "études"].map((etape, i) => (
          <li class="flex items-center gap-2" data-pas={i}>
            <span class="xp-pas-point inline-block h-1.5 w-1.5 rounded-full bg-white/25 transition-colors"></span>
            <span class="xp-pas-label hidden md:inline">{etape}</span>
          </li>
        ))}
      </ol>
      <div class="flex items-center gap-2">
        <button type="button" id="xp-capot-open" class="cursor-pointer rounded-full border border-white/20 px-3 py-2 text-[11px] text-white/60 transition-colors hover:border-lime hover:text-lime sm:px-4">
          Coulisses
        </button>
        <button type="button" data-open-contact class="cursor-pointer rounded-full bg-white px-4 py-2 text-[14px] font-medium text-black transition-colors hover:bg-white/90">
          Contact
        </button>
      </div>
    </nav>

    <!-- ═════════ SCÈNE : UNE VUE À LA FOIS ═════════ -->
    <div id="xp-scene" class="relative min-h-0 flex-1">

      <!-- ——— VUE ACCUEIL ——— -->
      <section data-vue="accueil" class="xp-vue" aria-label="Étape 1 : votre site">
        <div id="xp-hero" class="relative isolate flex min-h-full flex-col justify-center overflow-hidden px-6 py-10 md:px-12">
          <div
            class="pointer-events-none absolute inset-0 -z-30"
            style="background: radial-gradient(800px 520px at 22% 12%, oklch(0.92 0.21 125 / 0.08), transparent 68%);"
            aria-hidden="true"
          ></div>
          <div class="xp-depth pointer-events-none absolute -left-44 top-1/4 -z-20 h-[520px] w-[520px] rounded-full bg-lime/12 blur-3xl" data-depth="0.35" aria-hidden="true"></div>
          <div class="xp-depth pointer-events-none absolute -right-36 bottom-8 -z-20 h-[420px] w-[420px] rounded-full bg-lime/[0.07] blur-3xl" data-depth="0.55" aria-hidden="true"></div>

          <div class="relative mx-auto w-full max-w-5xl">
            <div class="mb-8 inline-flex w-fit items-center gap-3 rounded-full border border-lime/30 bg-black/40 px-4 py-2 text-[12px] text-lime/90 backdrop-blur-sm">
              <span class="relative flex h-2 w-2">
                <span id="xp-led-ping" class="absolute inline-flex h-full w-full animate-ping rounded-full bg-lime opacity-60"></span>
                <span id="xp-led" class="relative inline-flex h-2 w-2 rounded-full bg-lime"></span>
              </span>
              <span id="xp-console" aria-live="polite">démarrage…</span>
            </div>

            <h1 class="max-w-[900px] text-[clamp(2.3rem,6.5vw,5.2rem)] font-light leading-[0.98] tracking-[-0.04em]">
              <span class="xp-line block overflow-hidden"><span class="xp-word">Votre entreprise,</span></span>
              <span class="xp-line block overflow-hidden"><span class="xp-word"><em class="font-normal text-lime">étudiée par l'IA,</em></span></span>
              <span class="xp-line block overflow-hidden"><span class="xp-word"><em class="font-normal text-lime">sous vos yeux.</em></span></span>
            </h1>

            <p class="xp-fade mt-7 max-w-xl text-lg leading-relaxed text-white/70">
              Un parcours en trois temps : j'analyse votre site et je le mesure, puis
              <strong class="font-medium text-white">vous choisissez l'étude</strong> — concurrents, cibles
              idéales, nouvel axe marketing — rédigée pour vous, en direct.
            </p>

            <form id="xp-url-form" class="xp-fade mt-9 flex w-full max-w-xl gap-2">
              <input
                id="xp-url-input"
                type="text"
                maxlength="300"
                inputmode="url"
                placeholder="votre-entreprise.fr"
                class="w-full rounded-full border border-lime/40 bg-black/40 px-5 py-3.5 text-[15px] text-white placeholder:text-white/35 outline-none backdrop-blur-sm transition-colors focus:border-lime"
                autocomplete="url"
                autocapitalize="off"
                spellcheck="false"
              />
              <button type="submit" id="xp-url-go" class="shrink-0 cursor-pointer rounded-full bg-lime px-6 py-3.5 text-[15px] font-medium text-black transition-colors hover:bg-lime/90 disabled:cursor-wait disabled:opacity-50">
                Analyser
              </button>
            </form>
            <div class="xp-fade mt-3 text-xs text-white/55">
              Lecture publique de votre site, rien n'est stocké. Pas de site ?
              <button type="button" id="xp-vers-quiz" class="cursor-pointer text-white/65 underline underline-offset-4 hover:text-lime">Commencez par le diagnostic en 5 questions.</button>
            </div>
          </div>
        </div>
      </section>

      <!-- ——— VUE AUDIT ——— -->
      <section data-vue="audit" class="xp-vue" hidden aria-label="Étape 2 : lecture et audit de votre site">
        <div class="mx-auto max-w-7xl px-6 py-10 md:px-12">
          <div class="mb-5 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
            <span class="h-px w-6 bg-lime"></span> Lecture — j'analyse votre site
          </div>
          <h2 class="max-w-3xl text-[clamp(1.8rem,4vw,3rem)] font-light leading-[1.05] tracking-[-0.03em]">
            Votre entreprise, <em class="text-lime">vue par l'IA.</em>
          </h2>

          <div class="mt-8 grid gap-5 lg:grid-cols-[1.05fr_1fr] lg:items-stretch">
            <div class="rounded-2xl border border-white/12 bg-black/40 p-6 backdrop-blur-sm md:p-7">
              <div class="flex items-baseline justify-between gap-3">
                <div class="text-[12px] text-lime">analyse en cours</div>
                <span id="xp-analyse-statut" class="text-[11px] text-white/50">en attente</span>
              </div>
              <div id="xp-analyse-source" class="mt-2 hidden items-center gap-2 text-[11px] text-white/50">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-lime"></span>
                source lue : <span id="xp-analyse-domaine" class="text-white/75"></span>
              </div>
              <div id="xp-skills" class="mt-5 space-y-4 text-[12px]"></div>
            </div>

            <div class="flex flex-col items-center justify-center rounded-2xl border border-white/12 bg-white/[0.02] p-6 md:p-7">
              <div class="self-start text-[11px] uppercase tracking-[0.22em] text-white/55">Profil de présence en ligne</div>
              <canvas id="xp-radar" width="640" height="560" class="mt-2 w-full max-w-[360px]" role="img" aria-label="Radar des cinq scores d'audit du site"></canvas>
            </div>
          </div>

          <div class="mt-5 grid grid-cols-2 gap-px overflow-hidden rounded-2xl bg-white/10 md:grid-cols-4">
            {[
              ["xp-t-ttfb", "Temps de réponse", "ms"],
              ["xp-t-poids", "Poids de la page", "Ko"],
              ["xp-t-jsonld", "Données structurées", "blocs"],
              ["xp-t-alt", "Images décrites", "%"],
            ].map(([id, label, unite]) => (
              <div class="bg-[oklch(0.185_0.009_70)] p-5 md:p-6">
                <div class="text-[12px] text-white/65">{label}</div>
                <div class="mt-2 text-3xl font-light text-lime"><span id={id}>—</span><span class="ml-1 text-sm text-white/50">{unite}</span></div>
              </div>
            ))}
          </div>

          <div id="xp-analyse-box" class="mt-5 rounded-2xl border border-lime/25 bg-lime/[0.04] p-6 md:p-8" aria-live="polite">
            <div class="flex flex-wrap items-baseline justify-between gap-3">
              <div class="text-[11px] uppercase tracking-[0.22em] text-lime">Ce que Julien ferait chez vous</div>
              <span id="xp-analyse-statut2" class="text-[11px] text-white/50"></span>
            </div>
            <p id="xp-analyse-texte" class="mt-4 min-h-[90px] whitespace-pre-line text-[15px] leading-relaxed text-white/85"></p>
          </div>

          <div id="xp-audit-suite" class="mt-6 hidden flex-wrap items-center gap-3">
            <button type="button" id="xp-vers-hub" class="group inline-flex cursor-pointer items-center gap-3 rounded-full bg-lime px-6 py-3.5 text-[15px] font-medium text-black transition-all hover:bg-lime/90">
              Choisir votre étude
              <span class="grid h-7 w-7 place-items-center rounded-full bg-black/10 transition-transform group-hover:translate-x-0.5">→</span>
            </button>
            <button type="button" data-open-booking class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-white/20 px-6 py-3.5 text-sm text-white/80 transition-colors hover:border-lime hover:text-lime">
              Ou directement : audit 30 min
            </button>
          </div>
        </div>
      </section>

      <!-- ——— VUE QUIZ (branche sans site) ——— -->
      <section data-vue="quiz" class="xp-vue" hidden aria-label="Étape 2 : diagnostic en cinq questions">
        <div class="mx-auto max-w-7xl px-6 py-10 md:px-12">
          <div class="mb-5 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
            <span class="h-px w-6 bg-lime"></span> Diagnostic — elle vous jauge
          </div>
          <h2 class="max-w-3xl text-[clamp(1.8rem,4vw,3rem)] font-light leading-[1.05] tracking-[-0.03em]">
            Cinq questions. <em class="text-lime">Un diagnostic écrit pour vous.</em>
          </h2>

          <div class="mt-8 grid gap-6 lg:grid-cols-[1.1fr_1fr] lg:items-start">
            <div id="xp-quiz-box" class="relative min-h-[300px] rounded-2xl border border-white/12 bg-white/[0.02] p-7 md:p-9">
              <div class="mb-6 flex items-center justify-between">
                <div class="text-[12px] text-white/55"><span id="xp-quiz-num">01</span> / 0{QUIZ.length}</div>
                <div class="h-1 w-40 overflow-hidden rounded-full bg-white/10">
                  <div id="xp-quiz-bar" class="h-full w-0 bg-lime transition-all duration-500"></div>
                </div>
              </div>
              <div id="xp-quiz-slide">
                <h3 id="xp-quiz-q" class="text-2xl font-medium leading-snug">{QUIZ[0].q}</h3>
                <div id="xp-quiz-opts" class="mt-6 flex flex-wrap gap-3"></div>
              </div>
              <div id="xp-quiz-recap" class="hidden">
                <div class="text-[11px] uppercase tracking-[0.22em] text-lime">Vos réponses</div>
                <ul id="xp-quiz-recap-liste" class="mt-4 space-y-2 text-sm text-white/70"></ul>
                <button type="button" id="xp-quiz-restart" class="mt-6 cursor-pointer text-[13px] text-white/55 underline-offset-4 hover:text-lime hover:underline">
                  Recommencer
                </button>
              </div>
            </div>

            <div id="xp-verdict-box" class="rounded-2xl border border-lime/25 bg-lime/[0.04] p-7 opacity-50 transition-opacity duration-500 md:p-9" aria-live="polite">
              <div class="flex items-center justify-between gap-4">
                <div class="text-[11px] uppercase tracking-[0.22em] text-lime">Verdict — généré en direct</div>
                <span id="xp-verdict-statut" class="text-[11px] text-white/50">en attente de vos réponses</span>
              </div>
              <p id="xp-verdict-texte" class="mt-5 min-h-[120px] whitespace-pre-line text-[15px] leading-relaxed text-white/85">
                Répondez aux cinq questions : le diagnostic s'écrira ici, mot à mot, pendant que le modèle réfléchit.
              </p>
              <div id="xp-quiz-suite" class="mt-6 hidden flex-wrap gap-3">
                <button type="button" id="xp-vers-hub2" class="group inline-flex cursor-pointer items-center gap-3 rounded-full bg-lime px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-lime/90">
                  Poursuivre — choisir votre étude
                  <span class="transition-transform group-hover:translate-x-0.5">→</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ——— VUE HUB : QUE VOULEZ-VOUS ÉTUDIER ? ——— -->
      <section data-vue="hub" class="xp-vue" hidden aria-label="Étape 3 : choisir votre étude">
        <div class="mx-auto flex min-h-full max-w-7xl flex-col px-6 py-10 md:px-12">
          <div class="mb-5 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
            <span class="h-px w-6 bg-lime"></span> Études — je raisonne pour vous
          </div>
          <h2 class="max-w-3xl text-[clamp(1.8rem,4vw,3rem)] font-light leading-[1.05] tracking-[-0.03em]">
            Que voulez-vous <em class="text-lime">étudier maintenant ?</em>
          </h2>
          <p id="xp-hub-contexte" class="mt-3 max-w-xl text-sm text-white/50"></p>

          <div class="mt-8 grid gap-4 sm:grid-cols-2" role="list">
            {[
              ["concurrence", "Concurrence", "Qui sont vos concurrents ?", "L'IA reconstitue votre paysage concurrentiel à partir de votre site et trouve où vous démarquer."],
              ["cibles", "Cibles idéales", "Vos trois cibles idéales", "L'IA les définit : qui a le plus besoin de vous, où les toucher, et la phrase qui leur parle."],
              ["axe", "Positionnement", "Un nouvel axe marketing", "L'IA propose trois angles différenciants ancrés dans votre contenu — et le premier pas de chacun."],
              ["semaine", "Projection", "Votre semaine avec un assistant", "L'IA projette trois moments concrets d'une semaine type où l'assistant travaille pour vous."],
            ].map(([cle, skill, titre, desc]) => (
              <button type="button" class="xp-carte-etude group cursor-pointer rounded-2xl border border-white/15 bg-white/[0.02] p-6 text-left transition-all hover:border-lime/60" data-etude={cle} role="listitem">
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-[11px] text-lime">{skill}</span>
                  <span class="xp-carte-fait hidden text-[11px] text-lime">fait ✓</span>
                </div>
                <div class="mt-3 text-lg font-medium leading-snug">{titre}</div>
                <p class="mt-2 text-sm leading-relaxed text-white/65">{desc}</p>
                <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-lime transition-transform group-hover:translate-x-0.5">Lancer l'étude →</div>
              </button>
            ))}
          </div>

          <div class="mt-6 flex flex-wrap items-center gap-3">
            <button type="button" id="xp-vers-assistant" class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-white/20 px-5 py-3 text-sm text-white/80 transition-colors hover:border-lime hover:text-lime">
              Ou discutez-en — l'assistant prépare l'audit
            </button>
            <button type="button" data-open-booking class="group inline-flex cursor-pointer items-center gap-3 rounded-full bg-lime px-6 py-3 text-[15px] font-medium text-black transition-all hover:bg-lime/90">
              <span class="grid h-7 w-7 place-items-center rounded-full bg-black/10 transition-transform group-hover:translate-x-0.5">→</span>
              Réserver l'audit 30 min
            </button>
          </div>

          <footer class="mt-auto pt-10 text-xs text-white/35">
            © 2026 Julien Tridat — Bordeaux · <a href="/" class="hover:text-white">Version classique du site</a> ·
            chaque texte de ce parcours est généré en direct — ouvrez les coulisses pour voir l'IA travailler.
          </footer>
        </div>
      </section>

      <!-- ——— VUE ÉTUDE (générique, configurée en JS) ——— -->
      <section data-vue="etude" class="xp-vue" hidden aria-label="Votre étude en cours">
        <div class="mx-auto max-w-7xl px-6 py-10 md:px-12">
          <div class="mb-5 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
            <span class="h-px w-6 bg-lime"></span> <span id="xp-etude-skill">étude</span>
          </div>
          <h2 id="xp-etude-titre" class="max-w-3xl text-[clamp(1.8rem,4vw,3rem)] font-light leading-[1.05] tracking-[-0.03em]"></h2>
          <p id="xp-etude-intro" class="mt-3 max-w-xl text-white/60"></p>

          <div id="xp-etude-form" class="mt-7 max-w-xl space-y-3"></div>

          <div class="mt-7 grid gap-5 lg:grid-cols-[1fr_1.25fr] lg:items-start">
            <div class="rounded-2xl border border-white/12 bg-black/40 p-6 backdrop-blur-sm">
              <div class="flex items-baseline justify-between gap-3">
                <div class="text-[12px] text-lime">analyse en cours</div>
                <span id="xp-etude-statut" class="text-[11px] text-white/50">en attente</span>
              </div>
              <div id="xp-etude-console" class="mt-4 space-y-2 text-[12px] leading-relaxed text-white/50">
                <p class="text-white/35">en attente de votre demande…</p>
              </div>
            </div>

            <div class="rounded-2xl border border-lime/25 bg-lime/[0.04] p-6 md:p-8" aria-live="polite">
              <div class="text-[11px] uppercase tracking-[0.22em] text-lime">L'étude, rédigée en direct</div>
              <p id="xp-etude-texte" class="mt-4 min-h-[140px] whitespace-pre-line text-[15px] leading-relaxed text-white/85">
                Lancez l'analyse : l'étude s'écrit ici, mot à mot.
              </p>
              <div id="xp-etude-suite" class="mt-6 hidden flex-wrap gap-3">
                <button type="button" data-open-booking class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-lime px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-lime/90">
                  On approfondit ? Audit 30 min →
                </button>
                <button type="button" id="xp-etude-retour" class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-white/20 px-5 py-2.5 text-sm text-white/80 transition-colors hover:border-lime hover:text-lime">
                  ← Autres études
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ——— VUE ASSISTANT (qualification) ——— -->
      <section data-vue="assistant" class="xp-vue" hidden aria-label="Assistant de qualification">
        <div class="mx-auto grid min-h-full max-w-7xl content-center gap-10 px-6 py-10 md:px-12 lg:grid-cols-[1fr_1.25fr] lg:items-start">
          <div>
            <div class="mb-5 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
              <span class="h-px w-6 bg-lime"></span> Dernier acte — elle vous écoute
            </div>
            <h2 class="text-[clamp(1.8rem,4vw,3rem)] font-light leading-[1.05] tracking-[-0.03em]">
              Racontez votre activité. <em class="text-lime">Elle prépare l'audit.</em>
            </h2>
            <p class="mt-5 max-w-md text-white/65">
              Quelques questions, un pré-diagnostic — exactement ce qu'un assistant de qualification fait chez mes clients,
              à ceci près qu'ici, c'est vous le prospect.
            </p>
            <p class="mt-4 max-w-md text-sm text-white/55">
              Conversation éphémère : rien n'est stocké, rien n'est envoyé à Julien. Le vrai rendez-vous, c'est le bouton sous la conversation.
            </p>
          </div>

          <div class="rounded-2xl border border-white/12 bg-white/[0.02] p-5 md:p-7">
            <div id="xp-chat-log" class="flex max-h-[46svh] min-h-[220px] flex-col gap-4 overflow-y-auto pr-1" aria-live="polite">
              <div class="xp-bulle-ia max-w-[85%] rounded-2xl rounded-tl-md border border-lime/20 bg-lime/[0.06] px-4 py-3 text-[14px] leading-relaxed text-white/85">
                Bonjour — je suis l'assistant de démonstration de Julien. Dites-moi en une phrase ce que fait votre entreprise, et je vous dis où un assistant IA travaillerait pour vous.
              </div>
            </div>
            <form id="xp-chat-form" class="mt-4 flex gap-2">
              <input
                id="xp-chat-input"
                type="text"
                maxlength="400"
                placeholder="Ex. : je dirige une PME de 12 personnes dans le bâtiment…"
                class="w-full rounded-full border border-white/15 bg-black/30 px-5 py-3 text-[15px] text-white placeholder:text-white/35 outline-none transition-colors focus:border-lime/60"
                autocomplete="off"
              />
              <button type="submit" id="xp-chat-go" class="shrink-0 cursor-pointer rounded-full bg-lime px-5 py-3 text-sm font-medium text-black transition-colors hover:bg-lime/90 disabled:cursor-wait disabled:opacity-50" aria-label="Envoyer">
                →
              </button>
            </form>
            <div class="mt-5 flex flex-wrap items-center justify-between gap-3 border-t border-white/10 pt-5">
              <button type="button" id="xp-assistant-retour" class="cursor-pointer text-[13px] text-white/55 underline-offset-4 hover:text-lime hover:underline">← Autres études</button>
              <button type="button" data-open-booking class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-lime px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-lime/90">
                Réserver l'audit 30 min →
              </button>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- ═════════ PANNEAU « SOUS LE CAPOT » ═════════ -->
    <aside
      id="xp-capot"
      class="fixed inset-x-3 bottom-3 z-50 hidden max-h-[55vh] flex-col overflow-hidden rounded-2xl border border-lime/30 bg-black/90 shadow-2xl shadow-black/60 backdrop-blur-md md:inset-x-auto md:right-6 md:bottom-6 md:w-[420px]"
      aria-label="Les coulisses : ce que l'IA vient de faire"
    >
      <div class="flex items-center justify-between border-b border-white/10 px-5 py-3">
        <span class="text-[12px] text-lime">les coulisses</span>
        <button type="button" id="xp-capot-close" class="cursor-pointer text-[12px] text-white/50 hover:text-white" aria-label="Fermer">Fermer</button>
      </div>
      <div class="grid grid-cols-3 gap-px border-b border-white/10 bg-white/10 text-[11px]">
        <div class="bg-black/90 px-4 py-3"><div class="text-white/50">IA</div><div id="xp-capot-moteur" class="mt-1 truncate text-lime">—</div></div>
        <div class="bg-black/90 px-4 py-3"><div class="text-white/50">temps de réponse</div><div id="xp-capot-latence" class="mt-1 text-lime">—</div></div>
        <div class="bg-black/90 px-4 py-3"><div class="text-white/50">morceaux reçus</div><div id="xp-capot-frags" class="mt-1 text-lime">—</div></div>
      </div>
      <div class="min-h-0 flex-1 space-y-4 overflow-y-auto px-5 py-4 text-[11px] leading-relaxed">
        <div>
          <div class="text-white/50">modèle</div>
          <div id="xp-capot-modele" class="mt-1 break-all text-white/75">rien pour l'instant — lancez l'analyse, une étude ou l'assistant.</div>
        </div>
        <div>
          <div class="text-white/50">la consigne donnée à l'IA</div>
          <pre id="xp-capot-system" class="mt-1 whitespace-pre-wrap break-words text-white/60">—</pre>
        </div>
        <div>
          <div class="text-white/50">le texte, reçu en direct</div>
          <div id="xp-capot-flux" class="mt-1 break-words text-white/60">—</div>
        </div>
      </div>
    </aside>
  </main>

  <style is:global>
    /* Parcours plein écran : pas de défilement global, chaque vue gère le sien. */
    html, body { height: 100%; overflow: hidden; }

    /* Vues du parcours */
    .xp-vue { position: absolute; inset: 0; overflow-y: auto; overscroll-behavior: contain; }
    .xp-vue[hidden] { display: none; }
    .xp-vue-sortie { opacity: 0; transform: translateY(-16px); transition: opacity .26s ease, transform .26s ease; }
    .xp-vue-entree { animation: xp-vue-in .4s cubic-bezier(.2,.7,.2,1); }
    @keyframes xp-vue-in { from { opacity: 0; transform: translateY(20px); } }

    /* Progression */
    .xp-pas-actif .xp-pas-point { background: oklch(0.92 0.21 125); box-shadow: 0 0 8px oklch(0.92 0.21 125 / .7); }
    .xp-pas-actif .xp-pas-label { color: oklch(0.92 0.21 125); }
    .xp-pas-fait .xp-pas-point { background: oklch(0.92 0.21 125 / .5); }

    /* Apparition du hero */
    .xp-word { display: inline-block; transform: translateY(110%); animation: xp-rise .9s cubic-bezier(.2,.7,.2,1) forwards; }
    .xp-line:nth-child(2) .xp-word { animation-delay: .18s; }
    .xp-line:nth-child(3) .xp-word { animation-delay: .36s; }
    .xp-fade { opacity: 0; animation: xp-in .8s ease .7s forwards; }
    @keyframes xp-rise { to { transform: translateY(0); } }
    @keyframes xp-in { to { opacity: 1; } }

    /* Options du quiz */
    .xp-opt { cursor: pointer; border: 1px solid oklch(1 0 0 / 15%); border-radius: 999px; padding: .55rem 1.1rem; font-size: 14px; color: oklch(1 0 0 / 75%); transition: border-color .2s, color .2s, background .2s, transform .2s; }
    .xp-opt:hover { border-color: oklch(0.92 0.21 125 / .6); color: oklch(0.92 0.21 125); transform: translateY(-1px); }
    .xp-slide-out { animation: xp-out .28s ease forwards; }
    .xp-slide-in { animation: xp-enter .34s cubic-bezier(.2,.7,.2,1); }
    @keyframes xp-out { to { opacity: 0; transform: translateX(-16px); } }
    @keyframes xp-enter { from { opacity: 0; transform: translateX(20px); } }

    /* Champs des études */
    .xp-champ { width: 100%; border: 1px solid oklch(1 0 0 / 16%); border-radius: 999px; background: oklch(0 0 0 / .3); color: white; padding: .7rem 1.25rem; font-size: 15px; outline: none; transition: border-color .2s; }
    .xp-champ:focus { border-color: oklch(0.92 0.21 125 / .6); }

    /* Bulles du chat */
    .xp-bulle-moi { align-self: flex-end; max-width: 85%; border-radius: 1rem; border-top-right-radius: .375rem; background: oklch(1 0 0 / 10%); padding: .75rem 1rem; font-size: 14px; line-height: 1.6; color: oklch(1 0 0 / .9); }
    .xp-bulle-ia { animation: xp-enter .3s ease; }

    /* Curseur d'écriture pendant le stream */
    .xp-encours::after { content: "▋"; color: oklch(0.92 0.21 125); animation: xp-clignote 1s steps(2) infinite; margin-left: 1px; }
    @keyframes xp-clignote { 50% { opacity: 0; } }

    @media (prefers-reduced-motion: reduce) {
      .xp-word { transform: none; animation: none; }
      .xp-fade { opacity: 1; animation: none; }
      .xp-slide-in, .xp-slide-out, .xp-bulle-ia, .xp-vue-entree { animation: none; }
      .xp-vue-sortie { transition: none; }
      .xp-depth { transform: none !important; }
    }
  </style>

  <script>
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const $ = (id: string) => document.getElementById(id)!;

    /* ————— Navigation du parcours : une vue à la fois ————— */
    const vues = new Map<string, HTMLElement>();
    document.querySelectorAll<HTMLElement>("[data-vue]").forEach((v) => vues.set(v.dataset.vue!, v));
    let vueActive = "accueil";
    const PAS: Record<string, number> = { accueil: 0, audit: 1, quiz: 1, hub: 2, etude: 2, assistant: 2 };
    const PRECEDENT: Record<string, () => string> = {
      audit: () => "accueil",
      quiz: () => "accueil",
      hub: () => (auditFait ? "audit" : quizRecap ? "quiz" : "accueil"),
      etude: () => "hub",
      assistant: () => "hub",
    };

    function majProgression() {
      const pas = PAS[vueActive] ?? 0;
      document.querySelectorAll<HTMLElement>("#xp-progression [data-pas]").forEach((li) => {
        const i = parseInt(li.dataset.pas!, 10);
        li.classList.toggle("xp-pas-actif", i === pas);
        li.classList.toggle("xp-pas-fait", i < pas);
      });
      $("xp-retour").classList.toggle("hidden", vueActive === "accueil");
    }

    function allerA(nom: string) {
      if (nom === vueActive || !vues.has(nom)) return;
      const courante = vues.get(vueActive)!;
      const suivante = vues.get(nom)!;
      const basculer = () => {
        courante.hidden = true;
        courante.classList.remove("xp-vue-sortie");
        suivante.hidden = false;
        suivante.scrollTop = 0;
        suivante.classList.add("xp-vue-entree");
        setTimeout(() => suivante.classList.remove("xp-vue-entree"), 450);
        vueActive = nom;
        majProgression();
        window.dispatchEvent(new Event("resize"));
      };
      if (reduced) basculer();
      else {
        courante.classList.add("xp-vue-sortie");
        setTimeout(basculer, 240);
      }
    }
    $("xp-retour").addEventListener("click", () => allerA(PRECEDENT[vueActive]?.() ?? "accueil"));
    majProgression();

    /* ————— Parallaxe douce des halos (plus de réseau de particules) ————— */
    const layers = [...document.querySelectorAll<HTMLElement>(".xp-depth")];
    if (!reduced && layers.length && window.matchMedia("(pointer: fine)").matches) {
      window.addEventListener("pointermove", (e) => {
        const px = (e.clientX / window.innerWidth) * 2 - 1;
        const py = (e.clientY / window.innerHeight) * 2 - 1;
        for (const el of layers) {
          const depth = parseFloat(el.dataset.depth || "0.3");
          el.style.transform = `translate3d(${px * 30 * depth}px, ${py * 20 * depth}px, 0)`;
        }
      }, { passive: true });
    }

    /* ————— Client SSE + panneau « sous le capot » ————— */
    const capot = {
      panel: $("xp-capot"),
      open() { this.panel.classList.remove("hidden"); this.panel.classList.add("flex"); },
      close() { this.panel.classList.add("hidden"); this.panel.classList.remove("flex"); },
      reset(mode: string) {
        $("xp-capot-moteur").textContent = "…";
        $("xp-capot-latence").textContent = "…";
        $("xp-capot-frags").textContent = "0";
        $("xp-capot-modele").textContent = `requête « ${mode} » en cours…`;
        $("xp-capot-system").textContent = "—";
        $("xp-capot-flux").textContent = "";
      },
    };
    $("xp-capot-open").addEventListener("click", () => capot.open());
    $("xp-capot-close").addEventListener("click", () => capot.close());

    type Handlers = { meta?: (d: any) => void; delta?: (d: any) => void; done?: (d: any) => void; error?: (d: any) => void; etape?: (d: any) => void; skill?: (d: any) => void; audit?: (d: any) => void };

    // Contexte du parcours, partagé entre les vues.
    let siteUrlActive: string | null = null;
    let quizRecap: string | null = null;
    let auditFait = false;
    const etudesFaites = new Set<string>();

    async function streamIA(mode: string, messages: { role: string; content: string }[], h: Handlers, extra: Record<string, unknown> = {}) {
      capot.reset(mode);
      let frags = 0;
      const flux = $("xp-capot-flux");
      const res = await fetch("/api/experience", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ mode, messages, siteUrl: siteUrlActive ?? undefined, ...extra }),
      });
      if (!res.ok || !res.body) throw new Error(`API ${res.status}`);
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        const blocs = buffer.split("\n\n");
        buffer = blocs.pop() ?? "";
        for (const bloc of blocs) {
          let event = "message", data = "";
          for (const line of bloc.split("\n")) {
            if (line.startsWith("event: ")) event = line.slice(7);
            else if (line.startsWith("data: ")) data += line.slice(6);
          }
          if (!data) continue;
          const parsed = JSON.parse(data);
          if (event === "meta") {
            $("xp-capot-moteur").textContent = parsed.engine;
            $("xp-capot-modele").textContent = parsed.model + (parsed.source ? ` · source lue : ${new URL(parsed.source.url).hostname}` : "");
            $("xp-capot-system").textContent = parsed.system + "…";
          } else if (event === "etape") {
            $("xp-capot-modele").textContent = parsed.label;
          } else if (event === "delta") {
            frags += 1;
            $("xp-capot-frags").textContent = String(frags);
            flux.append(parsed.text);
            flux.scrollTop = flux.scrollHeight;
          } else if (event === "done") {
            $("xp-capot-latence").textContent = `${parsed.ms} ms`;
          }
          (h as any)[event]?.(parsed);
        }
      }
    }

    /* ————— Console du hero : état réel du moteur ————— */
    const consoleEl = $("xp-console");
    (async () => {
      const steps = ["démarrage…", "connexion à l'IA…"];
      for (const s of steps) {
        consoleEl.textContent = s;
        if (!reduced) await new Promise((r) => setTimeout(r, 550));
      }
      try {
        const res = await fetch("/api/experience");
        const info = await res.json();
        if (info.ok) consoleEl.textContent = `IA ${info.engine} en ligne — à vous de jouer.`;
        else throw new Error("aucun moteur");
      } catch {
        consoleEl.textContent = "démonstration hors ligne — la page reste visitable.";
        $("xp-led").classList.replace("bg-lime", "bg-white/40");
        $("xp-led-ping").classList.add("hidden");
      }
    })();

    /* ————— Radar (profil de présence en ligne) ————— */
    const AXES = [
      { skill: "performance", label: "Performance" },
      { skill: "seo", label: "Référencement" },
      { skill: "reseaux", label: "Réseaux" },
      { skill: "decouvrabilite", label: "Découvrabilité" },
      { skill: "aeo", label: "Lisibilité IA" },
    ];
    const radar = $("xp-radar") as HTMLCanvasElement;
    const rctx = radar.getContext("2d")!;
    const radarVal: Record<string, number> = {};
    const radarCible: Record<string, number> = {};
    AXES.forEach((a) => { radarVal[a.skill] = 0; radarCible[a.skill] = 0; });

    function dessinerRadar() {
      const W = radar.width, H = radar.height;
      const cx = W / 2, cy = H / 2 + 8, R = Math.min(W, H) / 2 - 92;
      rctx.clearRect(0, 0, W, H);
      const pt = (i: number, v: number) => {
        const ang = -Math.PI / 2 + (i * 2 * Math.PI) / AXES.length;
        return [cx + Math.cos(ang) * R * (v / 100), cy + Math.sin(ang) * R * (v / 100)];
      };
      rctx.strokeStyle = "rgba(255,255,255,0.10)";
      rctx.lineWidth = 1;
      for (const niveau of [25, 50, 75, 100]) {
        rctx.beginPath();
        AXES.forEach((_, i) => { const [x, y] = pt(i, niveau); i ? rctx.lineTo(x, y) : rctx.moveTo(x, y); });
        rctx.closePath(); rctx.stroke();
      }
      AXES.forEach((_, i) => { const [x, y] = pt(i, 100); rctx.beginPath(); rctx.moveTo(cx, cy); rctx.lineTo(x, y); rctx.stroke(); });
      rctx.beginPath();
      AXES.forEach((a, i) => { const [x, y] = pt(i, radarVal[a.skill]); i ? rctx.lineTo(x, y) : rctx.moveTo(x, y); });
      rctx.closePath();
      rctx.fillStyle = "rgba(200,255,61,0.13)"; rctx.fill();
      rctx.strokeStyle = "#c8ff3d"; rctx.lineWidth = 2.5; rctx.stroke();
      AXES.forEach((a, i) => {
        const [x, y] = pt(i, radarVal[a.skill]);
        rctx.beginPath(); rctx.arc(x, y, 5, 0, Math.PI * 2);
        rctx.fillStyle = "#c8ff3d"; rctx.fill();
        rctx.beginPath(); rctx.arc(x, y, 7, 0, Math.PI * 2);
        rctx.strokeStyle = "#0a0a0a"; rctx.lineWidth = 2; rctx.stroke();
      });
      rctx.font = "22px Geist, system-ui, sans-serif";
      rctx.textAlign = "center";
      AXES.forEach((a, i) => {
        const [x, y] = pt(i, 121);
        rctx.fillStyle = "rgba(255,255,255,0.6)";
        rctx.fillText(a.label, x, y);
        if (radarCible[a.skill] > 0) {
          rctx.fillStyle = "rgba(255,255,255,0.92)";
          rctx.font = "600 22px Geist, system-ui, sans-serif";
          rctx.fillText(String(Math.round(radarVal[a.skill])), x, y + 26);
          rctx.font = "22px Geist, system-ui, sans-serif";
        }
      });
    }
    let radarAnime = false;
    function animerRadar() {
      if (radarAnime) return;
      radarAnime = true;
      const pas = () => {
        let reste = false;
        for (const a of AXES) {
          const d = radarCible[a.skill] - radarVal[a.skill];
          if (Math.abs(d) > 0.5) { radarVal[a.skill] += d * (reduced ? 1 : 0.09); reste = true; }
          else radarVal[a.skill] = radarCible[a.skill];
        }
        dessinerRadar();
        if (reste) requestAnimationFrame(pas);
        else radarAnime = false;
      };
      requestAnimationFrame(pas);
    }
    dessinerRadar();

    function animerValeur(id: string, cible: number) {
      const el = $(id);
      if (reduced) { el.textContent = String(cible); return; }
      const t0 = performance.now();
      const pas = (t: number) => {
        const k = Math.min((t - t0) / 1200, 1);
        el.textContent = String(Math.round(cible * (1 - Math.pow(1 - k, 3))));
        if (k < 1) requestAnimationFrame(pas);
      };
      requestAnimationFrame(pas);
    }

    function afficherSkill(r: { skill: string; label: string; score: number; mesures: { label: string; valeur: string; ok: boolean }[] }) {
      const ligne = document.createElement("div");
      ligne.className = "xp-slide-in border-b border-white/8 pb-3 last:border-b-0";
      ligne.innerHTML =
        `<div class="flex items-baseline justify-between gap-3">
           <span class="text-lime">${r.label}</span>
           <span class="text-white/90">${r.score}<span class="text-white/50">/100</span></span>
         </div>
         <div class="mt-1.5 leading-relaxed text-white/50">` +
        r.mesures.map((m) => `${m.label} ${m.valeur} <span class="${m.ok ? "text-lime" : "text-white/35"}">${m.ok ? "✓" : "✗"}</span>`).join(" · ") +
        `</div>`;
      $("xp-skills").append(ligne);
      radarCible[r.skill] = r.score;
      animerRadar();
    }

    /* ————— Étape 1 → 2 : analyse du site ————— */
    let analyseEnCours = false;
    $("xp-url-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const brut = ($("xp-url-input") as HTMLInputElement).value.trim();
      if (!brut || analyseEnCours) return;
      analyseEnCours = true;
      const go = $("xp-url-go") as HTMLButtonElement;
      const texte = $("xp-analyse-texte");
      const setStatut = (t: string) => { $("xp-analyse-statut").textContent = t; $("xp-analyse-statut2").textContent = t; };
      go.disabled = true;
      allerA("audit");
      $("xp-skills").innerHTML = "";
      AXES.forEach((a) => { radarCible[a.skill] = 0; radarVal[a.skill] = 0; });
      dessinerRadar();
      for (const id of ["xp-t-ttfb", "xp-t-poids", "xp-t-jsonld", "xp-t-alt"]) $(id).textContent = "—";
      texte.textContent = "";
      texte.classList.add("xp-encours");
      setStatut("lecture du site…");
      $("xp-analyse-source").classList.add("hidden");
      $("xp-audit-suite").classList.add("hidden");
      siteUrlActive = brut;
      let ok = false;
      try {
        await streamIA("analyse", [{ role: "user", content: "Analyse mon entreprise à partir du contenu de son site." }], {
          etape: (d) => { setStatut(d.label); },
          skill: (d) => afficherSkill(d),
          audit: (d) => {
            animerValeur("xp-t-ttfb", d.tuiles.ttfbMs);
            animerValeur("xp-t-poids", d.tuiles.poidsKo);
            animerValeur("xp-t-jsonld", d.tuiles.jsonLd);
            if (d.tuiles.altPct === null) $("xp-t-alt").textContent = "—";
            else animerValeur("xp-t-alt", d.tuiles.altPct);
          },
          meta: (d) => {
            setStatut(`${d.engine} · en direct`);
            if (d.source) {
              siteUrlActive = d.source.url;
              $("xp-analyse-domaine").textContent = new URL(d.source.url).hostname + (d.source.titre ? ` — « ${d.source.titre} »` : "");
              $("xp-analyse-source").classList.remove("hidden");
              $("xp-analyse-source").classList.add("flex");
            }
          },
          delta: (d) => { texte.append(d.text); ok = true; },
          error: (d) => { texte.textContent = d.message; setStatut("échec de lecture"); siteUrlActive = null; },
          done: (d) => { if (ok) setStatut(`mesuré et rédigé en ${(d.ms / 1000).toFixed(1)} s`); },
        });
      } catch {
        texte.textContent = "La démonstration IA est momentanément indisponible — réessayez dans un instant.";
        setStatut("hors ligne");
        siteUrlActive = null;
      }
      texte.classList.remove("xp-encours");
      if (ok) {
        auditFait = true;
        $("xp-audit-suite").classList.remove("hidden");
        $("xp-audit-suite").classList.add("flex");
      }
      go.disabled = false;
      analyseEnCours = false;
    });

    $("xp-vers-quiz").addEventListener("click", () => allerA("quiz"));
    $("xp-vers-hub").addEventListener("click", () => { majHub(); allerA("hub"); });

    /* ————— Étape 2 bis : quiz (branche sans site) ————— */
    const QUIZ: { q: string; options: string[]; cle: string }[] = JSON.parse($("xp-quiz-data").textContent!);
    let quizIndex = 0;
    const quizReponses: { cle: string; valeur: string }[] = [];

    const renderQuestion = () => {
      const item = QUIZ[quizIndex];
      $("xp-quiz-num").textContent = String(quizIndex + 1).padStart(2, "0");
      ($("xp-quiz-bar") as HTMLElement).style.width = `${(quizIndex / QUIZ.length) * 100}%`;
      $("xp-quiz-q").textContent = item.q;
      const opts = $("xp-quiz-opts");
      opts.innerHTML = "";
      for (const option of item.options) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "xp-opt";
        btn.textContent = option;
        btn.addEventListener("click", () => choisir(option));
        opts.append(btn);
      }
      $("xp-quiz-slide").classList.add("xp-slide-in");
      setTimeout(() => $("xp-quiz-slide").classList.remove("xp-slide-in"), 400);
    };

    const choisir = (valeur: string) => {
      quizReponses.push({ cle: QUIZ[quizIndex].cle, valeur });
      quizIndex += 1;
      if (quizIndex < QUIZ.length) {
        const slide = $("xp-quiz-slide");
        slide.classList.add("xp-slide-out");
        setTimeout(() => { slide.classList.remove("xp-slide-out"); renderQuestion(); }, reduced ? 0 : 260);
      } else {
        ($("xp-quiz-bar") as HTMLElement).style.width = "100%";
        $("xp-quiz-slide").classList.add("hidden");
        $("xp-quiz-recap").classList.remove("hidden");
        $("xp-quiz-recap-liste").innerHTML = quizReponses
          .map((r) => `<li class="flex gap-2"><span class="text-lime">+</span><span>${r.cle} : ${r.valeur}</span></li>`)
          .join("");
        lancerVerdict();
      }
    };

    const lancerVerdict = async () => {
      const box = $("xp-verdict-box");
      const texte = $("xp-verdict-texte");
      const statut = $("xp-verdict-statut");
      box.style.opacity = "1";
      texte.textContent = "";
      texte.classList.add("xp-encours");
      statut.textContent = "le modèle rédige…";
      const recap = quizReponses.map((r, i) => `${i + 1}. ${r.cle} : ${r.valeur}`).join("\n");
      quizRecap = recap;
      try {
        await streamIA("quiz", [{ role: "user", content: `Mes réponses au diagnostic :\n${recap}` }], {
          meta: (d) => { statut.textContent = `${d.engine} · en direct`; },
          delta: (d) => { texte.append(d.text); },
          error: (d) => { texte.textContent = d.message; },
          done: (d) => { statut.textContent = `généré en ${(d.ms / 1000).toFixed(1)} s`; },
        });
      } catch {
        texte.textContent = "La démonstration IA est momentanément indisponible — réessayez dans un instant.";
        statut.textContent = "hors ligne";
      }
      texte.classList.remove("xp-encours");
      $("xp-quiz-suite").classList.remove("hidden");
      $("xp-quiz-suite").classList.add("flex");
    };

    $("xp-quiz-restart").addEventListener("click", () => {
      quizIndex = 0;
      quizReponses.length = 0;
      quizRecap = null;
      $("xp-quiz-recap").classList.add("hidden");
      $("xp-quiz-slide").classList.remove("hidden");
      $("xp-quiz-suite").classList.add("hidden");
      ($("xp-verdict-box") as HTMLElement).style.opacity = "0.5";
      $("xp-verdict-texte").textContent = "Répondez aux cinq questions : le diagnostic s'écrira ici, mot à mot, pendant que le modèle réfléchit.";
      $("xp-verdict-statut").textContent = "en attente de vos réponses";
      renderQuestion();
    });

    renderQuestion();
    $("xp-vers-hub2").addEventListener("click", () => { majHub(); allerA("hub"); });

    /* ————— Étape 3 : hub des études ————— */
    function majHub() {
      $("xp-hub-contexte").textContent = siteUrlActive
        ? `Chaque étude s'appuie sur la lecture de ${new URL(siteUrlActive).hostname} et sur les signaux mesurés.`
        : quizRecap
          ? "Chaque étude s'appuie sur vos réponses au diagnostic."
          : "Sans site ni diagnostic, chaque étude vous demandera une phrase sur votre activité.";
      document.querySelectorAll<HTMLElement>(".xp-carte-etude").forEach((carte) => {
        carte.querySelector(".xp-carte-fait")!.classList.toggle("hidden", !etudesFaites.has(carte.dataset.etude!));
      });
    }

    type ConfigEtude = { skill: string; mode: string; titre: string; intro: string; demande: string };
    const ETUDES: Record<string, ConfigEtude> = {
      concurrence: {
        skill: "Concurrence", mode: "concurrents",
        titre: "Qui sont vos concurrents ?",
        intro: "L'IA reconstitue votre paysage concurrentiel à partir de votre site — profils de concurrents, leur faille commune, et le terrain où vous démarquer.",
        demande: "Reconstitue mon paysage concurrentiel et dis-moi où me démarquer.",
      },
      cibles: {
        skill: "Cibles idéales", mode: "cibles",
        titre: "Vos trois cibles idéales",
        intro: "L'IA définit les trois clients qui ont le plus besoin de vous — qui ils sont, où les toucher, et la première phrase qui leur parle.",
        demande: "Définis mes trois cibles idéales.",
      },
      axe: {
        skill: "Positionnement", mode: "axe",
        titre: "Un nouvel axe marketing",
        intro: "L'IA propose trois angles différenciants, ancrés dans votre contenu réel et vos mesures — et le premier pas concret de chacun.",
        demande: "Propose-moi un nouvel axe marketing.",
      },
      semaine: {
        skill: "Projection", mode: "secteur",
        titre: "Votre semaine avec un assistant",
        intro: "L'IA projette trois moments concrets d'une semaine type où l'assistant travaille pour vous, pendant que vous faites votre métier.",
        demande: "Projette ma semaine type avec un assistant installé.",
      },
    };

    let etudeEnCours = false;

    // Le contexte vient du site lu ou du diagnostic. À défaut seulement, une phrase déclarée.
    function aDuContexte(): boolean { return !!siteUrlActive || !!quizRecap; }
    function suffixeContexte(): string {
      if (siteUrlActive) return "";
      if (quizRecap) return `\nContexte déclaré via le diagnostic :\n${quizRecap}`;
      const champ = document.getElementById("xp-etude-contexte") as HTMLInputElement | null;
      return champ?.value.trim() ? `\nMon activité : ${champ.value.trim()}` : "";
    }

    function ligneConsole(texte: string) {
      const console = $("xp-etude-console");
      if (console.firstElementChild?.classList.contains("text-white/35")) console.innerHTML = "";
      const p = document.createElement("p");
      p.className = "xp-slide-in";
      p.innerHTML = `<span class="text-lime">•</span> ${texte}`;
      console.append(p);
      console.scrollTop = console.scrollHeight;
    }

    function ouvrirEtude(cle: string) {
      const config = ETUDES[cle];
      $("xp-etude-skill").textContent = config.skill;
      $("xp-etude-titre").textContent = config.titre;
      $("xp-etude-intro").textContent = config.intro;
      $("xp-etude-statut").textContent = "en attente";
      $("xp-etude-console").innerHTML = `<p class="text-white/35">démarrage…</p>`;
      $("xp-etude-texte").textContent = "";
      $("xp-etude-suite").classList.add("hidden");
      const zone = $("xp-etude-form");
      zone.innerHTML = "";

      if (aDuContexte()) {
        // Contexte connu : le moteur part tout seul, aucune saisie.
        allerA("etude");
        lancerEtude(cle);
        return;
      }

      // Sans site ni diagnostic : une seule phrase suffit, puis le moteur fait le reste.
      const champ = document.createElement("input");
      champ.type = "text";
      champ.maxLength = 200;
      champ.className = "xp-champ";
      champ.id = "xp-etude-contexte";
      champ.placeholder = "votre activité en une phrase (ex. : menuiserie sur mesure à Bordeaux)";
      champ.autocomplete = "off";
      const bouton = document.createElement("button");
      bouton.type = "button";
      bouton.id = "xp-etude-go";
      bouton.className = "cursor-pointer rounded-full bg-lime px-6 py-3 text-[15px] font-medium text-black transition-colors hover:bg-lime/90 disabled:cursor-wait disabled:opacity-50";
      bouton.textContent = "Lancer l'étude →";
      bouton.addEventListener("click", () => {
        if (!champ.value.trim()) { champ.focus(); return; }
        lancerEtude(cle);
      });
      champ.addEventListener("keydown", (e) => { if (e.key === "Enter" && champ.value.trim()) lancerEtude(cle); });
      zone.append(champ, bouton);
      $("xp-etude-texte").textContent = "Dites votre activité en une phrase et l'IA produit l'étude.";
      allerA("etude");
      setTimeout(() => champ.focus(), 300);
    }

    async function lancerEtude(cle: string) {
      if (etudeEnCours) return;
      const config = ETUDES[cle];
      etudeEnCours = true;
      const go = document.getElementById("xp-etude-go") as HTMLButtonElement | null;
      if (go) go.disabled = true;
      const texte = $("xp-etude-texte");
      const statut = $("xp-etude-statut");
      texte.textContent = "";
      texte.classList.add("xp-encours");
      statut.textContent = "analyse en cours…";
      $("xp-etude-console").innerHTML = "";
      ligneConsole("démarrage…");
      let ok = false;
      try {
        await streamIA(config.mode, [{ role: "user", content: config.demande + suffixeContexte() }], {
          etape: (d) => { ligneConsole(d.label); statut.textContent = d.label; },
          meta: (d) => { ligneConsole(`${d.engine} — rédaction`); statut.textContent = `${d.engine} · en direct`; },
          delta: (d) => { texte.append(d.text); ok = true; },
          error: (d) => { texte.textContent = d.message; statut.textContent = "indisponible"; },
          done: (d) => { if (ok) { statut.textContent = `étude produite en ${(d.ms / 1000).toFixed(1)} s`; ligneConsole(`terminé en ${(d.ms / 1000).toFixed(1)} s`); } },
        });
      } catch {
        texte.textContent = "La démonstration IA est momentanément indisponible — réessayez dans un instant.";
        statut.textContent = "hors ligne";
      }
      texte.classList.remove("xp-encours");
      if (ok) {
        etudesFaites.add(cle);
        $("xp-etude-suite").classList.remove("hidden");
        $("xp-etude-suite").classList.add("flex");
      }
      if (go) go.disabled = false;
      etudeEnCours = false;
    }

    document.querySelectorAll<HTMLElement>(".xp-carte-etude").forEach((carte) => {
      carte.addEventListener("click", () => ouvrirEtude(carte.dataset.etude!));
    });
    $("xp-etude-retour").addEventListener("click", () => { majHub(); allerA("hub"); });
    $("xp-vers-assistant").addEventListener("click", () => allerA("assistant"));
    $("xp-assistant-retour").addEventListener("click", () => { majHub(); allerA("hub"); });

    /* ————— Assistant de qualification ————— */
    const chatMessages: { role: "user" | "assistant"; content: string }[] = [];
    let chatEnCours = false;
    const chatLog = $("xp-chat-log");
    const chatInput = $("xp-chat-input") as HTMLInputElement;
    const chatGo = $("xp-chat-go") as HTMLButtonElement;

    const bulle = (classe: string) => {
      const div = document.createElement("div");
      div.className = classe;
      chatLog.append(div);
      chatLog.scrollTop = chatLog.scrollHeight;
      return div;
    };

    $("xp-chat-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const contenu = chatInput.value.trim();
      if (!contenu || chatEnCours) return;
      chatEnCours = true;
      chatInput.value = "";
      chatInput.disabled = true;
      chatGo.disabled = true;

      bulle("xp-bulle-moi").textContent = contenu;
      chatMessages.push({ role: "user", content: contenu });

      const reponse = bulle("xp-bulle-ia max-w-[85%] rounded-2xl rounded-tl-md border border-lime/20 bg-lime/[0.06] px-4 py-3 text-[14px] leading-relaxed text-white/85 xp-encours");
      let texteIA = "";
      try {
        await streamIA("bot", chatMessages, {
          delta: (d) => { texteIA += d.text; reponse.textContent = texteIA; chatLog.scrollTop = chatLog.scrollHeight; },
          error: (d) => { texteIA = d.message; reponse.textContent = texteIA; },
        });
      } catch {
        texteIA = "La démonstration IA est momentanément indisponible — réessayez dans un instant.";
        reponse.textContent = texteIA;
      }
      reponse.classList.remove("xp-encours");
      if (texteIA) chatMessages.push({ role: "assistant", content: texteIA });

      if (chatMessages.filter((m) => m.role === "user").length >= 6) {
        chatInput.placeholder = "La suite se passe de vive voix — réservez l'audit ↓";
        chatInput.disabled = true;
        chatGo.disabled = true;
      } else {
        chatInput.disabled = false;
        chatGo.disabled = false;
        chatInput.focus();
      }
      chatEnCours = false;
    });
  </script>

  <script type="application/json" id="xp-quiz-data" set:html={JSON.stringify(QUIZ)} />
</BaseLayout>
