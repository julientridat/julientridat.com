---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/lib/site";

const title = "L'expérience — une IA au travail, en direct | Julien Tridat";
const description =
  "Donnez l'adresse de votre site : l'IA le lit et construit la page pour votre entreprise — analyse, quiz de maturité, scénarios métier et assistant de qualification, générés en direct.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "L'expérience — Julien Tridat",
    description,
    url: `${SITE.url}/experience`,
    author: { "@id": `${SITE.url}/#julien-tridat` },
  },
];

const QUIZ = [
  {
    q: "Votre équipe, c'est…",
    options: ["Moi, seul(e)", "2 à 10 personnes", "11 à 50 personnes", "Plus de 50"],
    cle: "Taille d'équipe",
  },
  {
    q: "Le temps part surtout dans…",
    options: ["Devis & propositions", "Relances & suivi client", "Administratif & saisie", "Contenus & communication"],
    cle: "Où part le temps",
  },
  {
    q: "Vos informations (clients, prix, documents) sont…",
    options: ["Dans ma tête", "Éparpillées (mails, Excel, papier)", "Centralisées dans un outil"],
    cle: "État des données",
  },
  {
    q: "L'IA, aujourd'hui, chez vous…",
    options: ["Jamais testée", "Testée, sans suite", "Utilisée de temps en temps", "Déjà dans nos process"],
    cle: "Usage actuel de l'IA",
  },
  {
    q: "Votre objectif n°1 :",
    options: ["Gagner du temps", "Vendre plus", "Réduire les erreurs", "Rendre l'équipe autonome"],
    cle: "Objectif prioritaire",
  },
];

const SECTEURS = ["Artisan menuisier", "Cabinet comptable", "Agence immobilière", "Restaurant", "Cabinet d'avocats", "E-commerce"];
---

<BaseLayout title={title} description={description} canonical={`${SITE.url}/experience`} jsonLd={jsonLd}>
  <main id="xp" class="bg-background text-foreground">
    <!-- ═════════ HERO — profondeur de champ + moteur réel ═════════ -->
    <section id="xp-hero" class="relative isolate flex min-h-screen flex-col overflow-hidden" style="perspective: 900px" data-blueprint="Hero — état du moteur IA en direct">
      <!-- Couches de profondeur (parallaxe + flou croissant vers l'arrière) -->
      <canvas id="xp-canvas" class="pointer-events-none absolute inset-0 -z-40 h-full w-full" aria-hidden="true"></canvas>
      <div class="xp-depth pointer-events-none absolute inset-0 -z-30" data-depth="0.12" aria-hidden="true">
        <svg class="h-full w-full opacity-[0.10]" style="filter: blur(1.5px)">
          <line x1="12%" y1="0" x2="8%" y2="100%" stroke="white" stroke-width="1" />
          <line x1="36%" y1="0" x2="40%" y2="100%" stroke="white" stroke-width="1" />
          <line x1="72%" y1="0" x2="66%" y2="100%" stroke="white" stroke-width="1" />
          <line x1="0" y1="30%" x2="100%" y2="25%" stroke="white" stroke-width="1" />
          <line x1="0" y1="74%" x2="100%" y2="80%" stroke="white" stroke-width="1" />
        </svg>
      </div>
      <div class="xp-depth pointer-events-none absolute -left-44 top-1/4 -z-20 h-[520px] w-[520px] rounded-full bg-lime/15 blur-3xl" data-depth="0.35" aria-hidden="true"></div>
      <div class="xp-depth pointer-events-none absolute -right-36 bottom-8 -z-20 h-[420px] w-[420px] rounded-full bg-lime/10 blur-3xl" data-depth="0.55" aria-hidden="true"></div>
      <div class="xp-depth pointer-events-none absolute left-1/2 top-12 -z-20 h-[260px] w-[260px] rounded-full bg-white/[0.04] blur-2xl" data-depth="0.8" aria-hidden="true"></div>

      <nav class="flex items-center justify-between px-6 py-6 md:px-12 md:py-8">
        <a href="/" class="flex items-center gap-3 text-[15px] font-medium tracking-tight">
          <span class="grid grid-cols-3 gap-[2px]" style="width:18px;height:18px" aria-hidden="true">
            {Array.from({ length: 9 }).map(() => <span class="block rounded-[2px] bg-lime" style="width:5px;height:5px" />)}
          </span>
          Julien Tridat
        </a>
        <div class="flex items-center gap-3">
          <a href="/" class="hidden text-[13px] text-white/50 transition-colors hover:text-white sm:block">← Version classique</a>
          <button type="button" data-open-contact class="cursor-pointer rounded-full bg-white px-5 py-2.5 text-[15px] font-medium text-black transition-colors hover:bg-white/90">
            Contact
          </button>
        </div>
      </nav>

      <div class="relative mx-auto flex w-full max-w-7xl flex-1 flex-col justify-center px-6 pb-16 md:px-12">
        <div class="mb-8 inline-flex w-fit items-center gap-3 rounded-full border border-lime/30 bg-black/40 px-4 py-2 font-mono text-[12px] text-lime/90 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span id="xp-led-ping" class="absolute inline-flex h-full w-full animate-ping rounded-full bg-lime opacity-60"></span>
            <span id="xp-led" class="relative inline-flex h-2 w-2 rounded-full bg-lime"></span>
          </span>
          <span id="xp-console" aria-live="polite">initialisation…</span>
        </div>

        <h1 class="max-w-[1050px] text-[clamp(2.5rem,7vw,6.2rem)] font-light leading-[0.98] tracking-[-0.04em]">
          <span class="xp-line block overflow-hidden"><span class="xp-word">Cette page ne parle</span></span>
          <span class="xp-line block overflow-hidden"><span class="xp-word">pas d'IA. <em class="font-normal text-lime">Elle pense,</em></span></span>
          <span class="xp-line block overflow-hidden"><span class="xp-word"><em class="font-normal text-lime">là, maintenant.</em></span></span>
        </h1>

        <p class="xp-fade mt-8 max-w-xl text-lg leading-relaxed text-white/70">
          Collez l'adresse de votre site : l'IA le lit en direct et
          <strong class="font-medium text-white">construit la suite de la page pour votre entreprise</strong> —
          la même mécanique que les assistants que j'installe.
        </p>

        <form id="xp-url-form" class="xp-fade mt-10 flex w-full max-w-xl gap-2">
          <input
            id="xp-url-input"
            type="text"
            maxlength="300"
            inputmode="url"
            placeholder="votre-entreprise.fr"
            class="w-full rounded-full border border-lime/40 bg-black/40 px-5 py-3.5 font-mono text-[15px] text-white placeholder:text-white/35 outline-none backdrop-blur-sm transition-colors focus:border-lime"
            autocomplete="url"
            autocapitalize="off"
            spellcheck="false"
          />
          <button type="submit" id="xp-url-go" class="shrink-0 cursor-pointer rounded-full bg-lime px-6 py-3.5 text-[15px] font-medium text-black transition-colors hover:bg-lime/90 disabled:cursor-wait disabled:opacity-50">
            Analyser
          </button>
        </form>
        <div class="xp-fade mt-3 text-xs text-white/45">
          Lecture publique de votre site, rien n'est stocké. Pas de site ?
          <a href="#xp-quiz" class="text-white/65 underline underline-offset-4 hover:text-lime">Faites le diagnostic en 5 questions.</a>
        </div>
      </div>
    </section>

    <!-- ═════════ ACTE 1 — ELLE LIT VOTRE SITE ═════════ -->
    <section id="xp-analyse" class="relative overflow-hidden border-t border-white/10 bg-[oklch(0.17_0_0)] px-6 py-24 md:px-12 md:py-32" data-blueprint="Acte 1 — analyse du site du visiteur en direct">
      <div class="xp-depth pointer-events-none absolute -left-28 top-10 -z-10 h-[400px] w-[400px] rounded-full bg-lime/10 blur-3xl" data-depth="0.45" aria-hidden="true"></div>
      <div class="mx-auto max-w-7xl">
        <div class="mb-6 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
          <span class="h-px w-6 bg-lime"></span> Acte 1 — elle lit votre site
        </div>
        <h2 class="max-w-3xl text-[clamp(2rem,4.5vw,3.5rem)] font-light leading-[1.05] tracking-[-0.03em]">
          Votre entreprise, <em class="text-lime">vue par l'IA.</em>
        </h2>
        <p class="mt-4 max-w-xl text-white/60">
          Mes skills d'audit parcourent votre site public et mesurent de vrais signaux — rien n'est inventé,
          tout s'affiche pendant qu'ils travaillent.
        </p>

        <div class="mt-10 grid gap-5 lg:grid-cols-[1.05fr_1fr] lg:items-stretch">
          <!-- Terminal des skills au travail -->
          <div class="rounded-2xl border border-white/12 bg-black/40 p-6 backdrop-blur-sm md:p-7">
            <div class="flex items-baseline justify-between gap-3">
              <div class="font-mono text-[12px] text-lime">mes skills au travail</div>
              <span id="xp-analyse-statut" class="font-mono text-[11px] text-white/40">en attente d'une adresse</span>
            </div>
            <div id="xp-analyse-source" class="mt-2 hidden items-center gap-2 font-mono text-[11px] text-white/50">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-lime"></span>
              source lue : <span id="xp-analyse-domaine" class="text-white/75"></span>
            </div>
            <div id="xp-skills" class="mt-5 space-y-4 font-mono text-[12px]">
              <p class="text-white/40">▸ cinq skills spécialisés (performance, référencement, présence sociale, découvrabilité, lisibilité IA) attendent l'adresse de votre site…</p>
            </div>
          </div>

          <!-- Radar : profil de présence en ligne -->
          <div class="flex flex-col items-center justify-center rounded-2xl border border-white/12 bg-white/[0.02] p-6 md:p-7">
            <div class="self-start text-[11px] uppercase tracking-[0.22em] text-white/45">Profil de présence en ligne</div>
            <canvas id="xp-radar" width="640" height="560" class="mt-2 w-full max-w-[360px]" role="img" aria-label="Radar des cinq scores d'audit du site"></canvas>
          </div>
        </div>

        <!-- Tuiles de mesures -->
        <div class="mt-5 grid grid-cols-2 gap-px overflow-hidden rounded-2xl bg-white/10 md:grid-cols-4">
          {[
            ["xp-t-ttfb", "Temps de réponse", "ms"],
            ["xp-t-poids", "Poids de la page", "Ko"],
            ["xp-t-jsonld", "Données structurées", "blocs"],
            ["xp-t-alt", "Images décrites", "%"],
          ].map(([id, label, unite]) => (
            <div class="bg-[oklch(0.17_0_0)] p-6">
              <div class="text-[12px] text-white/55">{label}</div>
              <div class="mt-2 text-3xl font-light text-lime"><span id={id}>—</span><span class="ml-1 text-sm text-white/40">{unite}</span></div>
            </div>
          ))}
        </div>

        <!-- Synthèse rédigée en direct -->
        <div id="xp-analyse-box" class="mt-5 rounded-2xl border border-lime/25 bg-lime/[0.04] p-7 opacity-60 transition-opacity duration-500 md:p-9" aria-live="polite">
          <div class="flex flex-wrap items-baseline justify-between gap-3">
            <div class="text-[11px] uppercase tracking-[0.22em] text-lime">Ce que Julien ferait chez vous</div>
            <span id="xp-analyse-statut2" class="font-mono text-[11px] text-white/40"></span>
          </div>
          <p id="xp-analyse-texte" class="mt-5 min-h-[110px] whitespace-pre-line text-[15px] leading-relaxed text-white/85">
            Collez l'adresse de votre site dans l'encart d'ouverture : les skills mesurent, puis l'IA rédige ici
            les trois assistants qu'elle installerait dans votre entreprise — en citant votre activité et vos mesures réelles.
          </p>
          <div id="xp-analyse-cta" class="mt-6 hidden">
            <button type="button" data-open-booking class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-lime px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-lime/90">
              On le fait en vrai ? Audit 30 min →
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ═════════ ACTE 2 — QUIZ MATURITÉ IA ═════════ -->
    <section id="xp-quiz" class="relative overflow-hidden border-t border-white/10 px-6 py-24 md:px-12 md:py-32" data-blueprint="Acte 2 — quiz + verdict généré par l'IA">
      <div class="xp-depth pointer-events-none absolute -right-28 top-16 -z-10 h-[380px] w-[380px] rounded-full bg-lime/10 blur-3xl" data-depth="0.4" aria-hidden="true"></div>
      <div class="mx-auto max-w-7xl">
        <div class="mb-6 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
          <span class="h-px w-6 bg-lime"></span> Acte 2 — elle vous jauge
        </div>
        <h2 class="max-w-3xl text-[clamp(2rem,4.5vw,3.5rem)] font-light leading-[1.05] tracking-[-0.03em]">
          Cinq questions. <em class="text-lime">Un diagnostic écrit pour vous.</em>
        </h2>
        <p class="mt-4 max-w-xl text-white/60">
          Pas de barème figé : l'IA lit vos cinq réponses et rédige son verdict — le même exercice que je fais en session stratégique.
        </p>

        <div class="mt-12 grid gap-6 lg:grid-cols-[1.1fr_1fr] lg:items-start">
          <!-- Carrousel de questions -->
          <div id="xp-quiz-box" class="relative min-h-[300px] rounded-2xl border border-white/12 bg-white/[0.02] p-7 md:p-9">
            <div class="mb-6 flex items-center justify-between">
              <div class="font-mono text-[12px] text-white/45"><span id="xp-quiz-num">01</span> / 0{QUIZ.length}</div>
              <div class="h-1 w-40 overflow-hidden rounded-full bg-white/10">
                <div id="xp-quiz-bar" class="h-full w-0 bg-lime transition-all duration-500"></div>
              </div>
            </div>
            <div id="xp-quiz-slide">
              <h3 id="xp-quiz-q" class="text-2xl font-medium leading-snug">{QUIZ[0].q}</h3>
              <div id="xp-quiz-opts" class="mt-6 flex flex-wrap gap-3"></div>
            </div>
            <div id="xp-quiz-recap" class="hidden">
              <div class="text-[11px] uppercase tracking-[0.22em] text-lime">Vos réponses</div>
              <ul id="xp-quiz-recap-liste" class="mt-4 space-y-2 text-sm text-white/70"></ul>
              <button type="button" id="xp-quiz-restart" class="mt-6 cursor-pointer text-[13px] text-white/45 underline-offset-4 hover:text-lime hover:underline">
                Recommencer
              </button>
            </div>
          </div>

          <!-- Verdict streamé -->
          <div id="xp-verdict-box" class="rounded-2xl border border-lime/25 bg-lime/[0.04] p-7 opacity-50 transition-opacity duration-500 md:p-9" aria-live="polite">
            <div class="flex items-center justify-between gap-4">
              <div class="text-[11px] uppercase tracking-[0.22em] text-lime">Verdict — généré en direct</div>
              <span id="xp-verdict-statut" class="font-mono text-[11px] text-white/40">en attente de vos réponses</span>
            </div>
            <p id="xp-verdict-texte" class="mt-5 min-h-[120px] whitespace-pre-line text-[15px] leading-relaxed text-white/85">
              Répondez aux cinq questions : le diagnostic s'écrira ici, mot à mot, pendant que le modèle réfléchit.
            </p>
            <div id="xp-verdict-cta" class="mt-6 hidden">
              <button type="button" data-open-booking class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-lime px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-lime/90">
                En parler 30 min avec Julien →
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═════════ ACTE 2 — GÉNÉRATEUR SECTORIEL ═════════ -->
    <section class="relative overflow-hidden border-t border-white/10 px-6 py-24 md:px-12 md:py-32" data-blueprint="Acte 3 — scénario métier généré en direct">
      <div class="xp-depth pointer-events-none absolute -left-32 bottom-0 -z-10 h-[420px] w-[420px] rounded-full bg-lime/10 blur-3xl" data-depth="0.5" aria-hidden="true"></div>
      <div class="mx-auto max-w-7xl">
        <div class="mb-6 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
          <span class="h-px w-6 bg-lime"></span> Acte 3 — elle parle votre métier
        </div>
        <h2 class="max-w-3xl text-[clamp(2rem,4.5vw,3.5rem)] font-light leading-[1.05] tracking-[-0.03em]">
          Dites-lui votre métier : <em class="text-lime">elle vous écrit votre semaine.</em>
        </h2>
        <p class="mt-4 max-w-xl text-white/60">
          Trois moments concrets d'une semaine avec un assistant installé — pour <span id="xp-secteur-tag" class="text-lime">votre activité</span>, pas pour une entreprise générique.
        </p>

        <div class="mt-10 grid gap-6 lg:grid-cols-[1fr_1.2fr] lg:items-start">
          <div>
            <form id="xp-secteur-form" class="flex gap-2">
              <input
                id="xp-secteur-input"
                type="text"
                maxlength="80"
                placeholder="Votre métier ou secteur…"
                class="w-full rounded-full border border-white/15 bg-black/30 px-5 py-3 text-[15px] text-white placeholder:text-white/35 outline-none transition-colors focus:border-lime/60"
                autocomplete="off"
              />
              <button type="submit" id="xp-secteur-go" class="shrink-0 cursor-pointer rounded-full bg-lime px-5 py-3 text-sm font-medium text-black transition-colors hover:bg-lime/90 disabled:cursor-wait disabled:opacity-50">
                Générer
              </button>
            </form>
            <div class="mt-4 flex flex-wrap gap-2">
              {SECTEURS.map((s) => (
                <button type="button" class="xp-secteur-chip cursor-pointer rounded-full border border-white/15 px-4 py-1.5 text-[13px] text-white/65 transition-colors hover:border-lime/60 hover:text-lime" data-secteur={s}>
                  {s}
                </button>
              ))}
            </div>
          </div>

          <div id="xp-secteur-box" class="rounded-2xl border border-white/12 bg-background/60 p-7 backdrop-blur-sm md:p-9" aria-live="polite">
            <div class="flex items-center justify-between gap-4">
              <div class="text-[11px] uppercase tracking-[0.22em] text-white/45">Votre semaine, avec assistant</div>
              <span id="xp-secteur-statut" class="font-mono text-[11px] text-white/40">en attente</span>
            </div>
            <p id="xp-secteur-texte" class="mt-5 min-h-[140px] whitespace-pre-line text-[15px] leading-relaxed text-white/85">
              Choisissez un exemple ou tapez votre métier — le scénario s'écrit sous vos yeux.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═════════ ACTE 3 — BOT DE QUALIFICATION ═════════ -->
    <section class="relative overflow-hidden border-t border-white/10 bg-[oklch(0.17_0_0)] px-6 py-24 md:px-12 md:py-32" data-blueprint="Acte 4 — assistant de qualification conversationnel">
      <div class="xp-depth pointer-events-none absolute -right-24 -top-24 -z-10 h-[360px] w-[360px] rounded-full bg-lime/10 blur-3xl" data-depth="0.45" aria-hidden="true"></div>
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1fr_1.25fr] lg:items-start">
        <div>
          <div class="mb-6 inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] text-lime">
            <span class="h-px w-6 bg-lime"></span> Acte 4 — elle vous écoute
          </div>
          <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-light leading-[1.05] tracking-[-0.03em]">
            Racontez votre activité. <em class="text-lime">Elle prépare l'audit.</em>
          </h2>
          <p class="mt-5 max-w-md text-white/65">
            Quelques questions, un pré-diagnostic — exactement ce qu'un assistant de qualification fait chez mes clients,
            à ceci près qu'ici, c'est vous le prospect.
          </p>
          <p class="mt-4 max-w-md text-sm text-white/45">
            Conversation éphémère : rien n'est stocké, rien n'est envoyé à Julien. Le vrai rendez-vous, c'est le bouton sous la conversation.
          </p>
        </div>

        <div class="rounded-2xl border border-white/12 bg-white/[0.02] p-5 md:p-7">
          <div id="xp-chat-log" class="flex max-h-[420px] min-h-[260px] flex-col gap-4 overflow-y-auto pr-1" aria-live="polite">
            <div class="xp-bulle-ia max-w-[85%] rounded-2xl rounded-tl-md border border-lime/20 bg-lime/[0.06] px-4 py-3 text-[14px] leading-relaxed text-white/85">
              Bonjour — je suis l'assistant de démonstration de Julien. Dites-moi en une phrase ce que fait votre entreprise, et je vous dis où un assistant IA travaillerait pour vous.
            </div>
          </div>
          <form id="xp-chat-form" class="mt-4 flex gap-2">
            <input
              id="xp-chat-input"
              type="text"
              maxlength="400"
              placeholder="Ex. : je dirige une PME de 12 personnes dans le bâtiment…"
              class="w-full rounded-full border border-white/15 bg-black/30 px-5 py-3 text-[15px] text-white placeholder:text-white/35 outline-none transition-colors focus:border-lime/60"
              autocomplete="off"
            />
            <button type="submit" id="xp-chat-go" class="shrink-0 cursor-pointer rounded-full bg-lime px-5 py-3 text-sm font-medium text-black transition-colors hover:bg-lime/90 disabled:cursor-wait disabled:opacity-50" aria-label="Envoyer">
              →
            </button>
          </form>
          <div class="mt-5 flex flex-wrap items-center justify-between gap-3 border-t border-white/10 pt-5">
            <span class="text-xs text-white/45">La suite se passe de vive voix :</span>
            <button type="button" data-open-booking class="inline-flex cursor-pointer items-center gap-2 rounded-full bg-lime px-5 py-2.5 text-sm font-medium text-black transition-colors hover:bg-lime/90">
              Réserver l'audit 30 min →
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ═════════ FINAL — SOUS LE CAPOT + CTA ═════════ -->
    <section class="relative overflow-hidden border-t border-white/10 px-6 py-28 md:px-12 md:py-40" data-blueprint="Final — transparence et appel à l'action">
      <div class="pointer-events-none absolute inset-0 -z-10" style="background: radial-gradient(700px 400px at 50% 0%, oklch(0.92 0.21 125 / 0.10), transparent 70%);" aria-hidden="true"></div>
      <div class="mx-auto max-w-4xl text-center">
        <div class="mb-6 text-[11px] uppercase tracking-[0.22em] text-lime">Dernier acte — elle se laisse démonter</div>
        <h2 class="text-[clamp(2.2rem,5.5vw,4.5rem)] font-light leading-[1.02] tracking-[-0.03em]">
          Rien de magique : <em class="text-lime">un système, visible.</em>
        </h2>
        <p class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-white/70">
          Chaque réponse que vous avez lue est sortie d'un modèle, token par token, cadré par des consignes précises.
          Ouvrez « sous le capot » pour voir le moteur, le prompt et le flux brut — c'est exactement ce que j'installe,
          en version calibrée sur votre métier.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <button type="button" id="xp-capot-open" class="cursor-pointer rounded-full border border-white/25 px-6 py-3 font-mono text-[13px] text-white/70 transition-colors hover:border-lime hover:text-lime">
            [ sous le capot ]
          </button>
          <button type="button" id="xp-blueprint" class="cursor-pointer rounded-full border border-white/25 px-6 py-3 font-mono text-[13px] text-white/70 transition-colors hover:border-lime hover:text-lime" aria-pressed="false">
            [ révéler la structure ]
          </button>
        </div>
        <div class="mt-14 flex flex-wrap items-center justify-center gap-4">
          <button type="button" data-open-booking class="group inline-flex cursor-pointer items-center gap-3 rounded-full bg-lime px-6 py-3.5 text-[15px] font-medium text-black transition-all hover:bg-lime/90">
            <span class="grid h-7 w-7 place-items-center rounded-full bg-black/10 transition-transform group-hover:translate-x-0.5">→</span>
            Installons ça chez vous — audit 30 min
          </button>
          <a href="/realisations" class="inline-flex items-center gap-2 rounded-full border border-white/20 px-6 py-3.5 text-sm text-white/80 transition-colors hover:border-lime hover:text-lime">
            Voir les cas clients
          </a>
        </div>
      </div>
    </section>

    <footer class="border-t border-white/10 px-6 py-10 text-center text-xs text-white/40 md:px-12">
      © 2026 Julien Tridat — Bordeaux · <a href="/" class="hover:text-white">Version classique du site</a>
    </footer>

    <!-- ═════════ PANNEAU « SOUS LE CAPOT » ═════════ -->
    <aside
      id="xp-capot"
      class="fixed inset-x-3 bottom-3 z-50 hidden max-h-[55vh] flex-col overflow-hidden rounded-2xl border border-lime/30 bg-black/90 shadow-2xl shadow-black/60 backdrop-blur-md md:inset-x-auto md:right-6 md:bottom-6 md:w-[420px]"
      aria-label="Sous le capot : détails techniques de la dernière génération"
    >
      <div class="flex items-center justify-between border-b border-white/10 px-5 py-3">
        <span class="font-mono text-[12px] text-lime">sous le capot</span>
        <button type="button" id="xp-capot-close" class="cursor-pointer font-mono text-[12px] text-white/50 hover:text-white" aria-label="Fermer">[ fermer ]</button>
      </div>
      <div class="grid grid-cols-3 gap-px border-b border-white/10 bg-white/10 font-mono text-[11px]">
        <div class="bg-black/90 px-4 py-3"><div class="text-white/40">moteur</div><div id="xp-capot-moteur" class="mt-1 truncate text-lime">—</div></div>
        <div class="bg-black/90 px-4 py-3"><div class="text-white/40">latence</div><div id="xp-capot-latence" class="mt-1 text-lime">—</div></div>
        <div class="bg-black/90 px-4 py-3"><div class="text-white/40">fragments</div><div id="xp-capot-frags" class="mt-1 text-lime">—</div></div>
      </div>
      <div class="min-h-0 flex-1 space-y-4 overflow-y-auto px-5 py-4 font-mono text-[11px] leading-relaxed">
        <div>
          <div class="text-white/40">modèle</div>
          <div id="xp-capot-modele" class="mt-1 break-all text-white/75">aucune génération pour l'instant — lancez le quiz, le générateur ou l'assistant.</div>
        </div>
        <div>
          <div class="text-white/40">consigne système (extrait, définie côté serveur)</div>
          <pre id="xp-capot-system" class="mt-1 whitespace-pre-wrap break-words text-white/60">—</pre>
        </div>
        <div>
          <div class="text-white/40">flux brut (chaque fragment reçu, dans l'ordre)</div>
          <div id="xp-capot-flux" class="mt-1 break-words text-white/60">—</div>
        </div>
      </div>
    </aside>
  </main>

  <style is:global>
    /* Apparition du hero */
    .xp-word { display: inline-block; transform: translateY(110%); animation: xp-rise .9s cubic-bezier(.2,.7,.2,1) forwards; }
    .xp-line:nth-child(2) .xp-word { animation-delay: .18s; }
    .xp-line:nth-child(3) .xp-word { animation-delay: .36s; }
    .xp-fade { opacity: 0; animation: xp-in .8s ease .7s forwards; }
    @keyframes xp-rise { to { transform: translateY(0); } }
    @keyframes xp-in { to { opacity: 1; } }

    /* Options du quiz */
    .xp-opt { cursor: pointer; border: 1px solid oklch(1 0 0 / 15%); border-radius: 999px; padding: .55rem 1.1rem; font-size: 14px; color: oklch(1 0 0 / 75%); transition: border-color .2s, color .2s, background .2s, transform .2s; }
    .xp-opt:hover { border-color: oklch(0.92 0.21 125 / .6); color: oklch(0.92 0.21 125); transform: translateY(-1px); }
    .xp-slide-out { animation: xp-out .28s ease forwards; }
    .xp-slide-in { animation: xp-enter .34s cubic-bezier(.2,.7,.2,1); }
    @keyframes xp-out { to { opacity: 0; transform: translateX(-16px); } }
    @keyframes xp-enter { from { opacity: 0; transform: translateX(20px); } }

    /* Bulles du chat */
    .xp-bulle-moi { align-self: flex-end; max-width: 85%; border-radius: 1rem; border-top-right-radius: .375rem; background: oklch(1 0 0 / 10%); padding: .75rem 1rem; font-size: 14px; line-height: 1.6; color: oklch(1 0 0 / .9); }
    .xp-bulle-ia { animation: xp-enter .3s ease; }

    /* Curseur d'écriture pendant le stream */
    .xp-encours::after { content: "▋"; color: oklch(0.92 0.21 125); animation: xp-clignote 1s steps(2) infinite; margin-left: 1px; }
    @keyframes xp-clignote { 50% { opacity: 0; } }

    /* Mode blueprint */
    .xp-reveal [data-blueprint] { outline: 1px dashed oklch(0.92 0.21 125 / .55); outline-offset: -8px; position: relative; }
    .xp-reveal [data-blueprint]::after { content: attr(data-blueprint); position: absolute; top: 10px; left: 10px; z-index: 40; font-family: ui-monospace, monospace; font-size: 11px; color: oklch(0.92 0.21 125); background: oklch(0.145 0 0 / .9); border: 1px solid oklch(0.92 0.21 125 / .4); padding: 4px 10px; border-radius: 999px; }

    @media (prefers-reduced-motion: reduce) {
      .xp-word { transform: none; animation: none; }
      .xp-fade { opacity: 1; animation: none; }
      .xp-slide-in, .xp-slide-out, .xp-bulle-ia { animation: none; }
      .xp-depth { transform: none !important; }
    }
  </style>

  <script>
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const $ = (id: string) => document.getElementById(id)!;

    /* ————— Profondeur de champ : particules + parallaxe multi-couches ————— */
    const canvas = $("xp-canvas") as HTMLCanvasElement;
    const hero = $("xp-hero");
    if (!reduced && canvas) {
      const ctx = canvas.getContext("2d")!;
      const N = window.innerWidth < 768 ? 34 : 70;
      let W = 0, H = 0;
      const dots = Array.from({ length: N }, () => ({
        x: Math.random(), y: Math.random(), z: 0.3 + Math.random() * 0.7,
        vx: (Math.random() - 0.5) * 0.00022, vy: (Math.random() - 0.5) * 0.00022,
      }));
      const resize = () => { W = canvas.width = hero.clientWidth; H = canvas.height = hero.clientHeight; };
      resize();
      window.addEventListener("resize", resize);
      const tick = () => {
        ctx.clearRect(0, 0, W, H);
        for (const d of dots) {
          d.x = (d.x + d.vx * d.z + 1) % 1;
          d.y = (d.y + d.vy * d.z + 1) % 1;
          // z proche → net et lumineux ; z lointain → petit et estompé (profondeur de champ)
          ctx.beginPath();
          ctx.arc(d.x * W, d.y * H, 1 + d.z * 1.8, 0, Math.PI * 2);
          ctx.fillStyle = `oklch(0.92 0.21 125 / ${0.06 + d.z * 0.24})`;
          ctx.fill();
        }
        for (let i = 0; i < dots.length; i++) {
          for (let j = i + 1; j < dots.length; j++) {
            const a = dots[i], b = dots[j];
            const dx = (a.x - b.x) * W, dy = (a.y - b.y) * H;
            const dist = Math.hypot(dx, dy);
            if (dist < 110) {
              ctx.beginPath();
              ctx.moveTo(a.x * W, a.y * H);
              ctx.lineTo(b.x * W, b.y * H);
              ctx.strokeStyle = `oklch(0.92 0.21 125 / ${(1 - dist / 110) * 0.10})`;
              ctx.stroke();
            }
          }
        }
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }

    // Parallaxe : chaque couche .xp-depth bouge selon sa profondeur (pointeur + défilement).
    const layers = [...document.querySelectorAll<HTMLElement>(".xp-depth")];
    if (!reduced && layers.length) {
      let px = 0, py = 0;
      const apply = () => {
        const sy = window.scrollY;
        for (const el of layers) {
          const depth = parseFloat(el.dataset.depth || "0.3");
          el.style.transform = `translate3d(${px * 30 * depth}px, ${py * 20 * depth - sy * depth * 0.15}px, 0)`;
        }
      };
      if (window.matchMedia("(pointer: fine)").matches) {
        window.addEventListener("pointermove", (e) => {
          px = (e.clientX / window.innerWidth) * 2 - 1;
          py = (e.clientY / window.innerHeight) * 2 - 1;
          apply();
        }, { passive: true });
      }
      window.addEventListener("scroll", apply, { passive: true });
    }

    /* ————— Client SSE + panneau « sous le capot » ————— */
    const capot = {
      panel: $("xp-capot"),
      open() { this.panel.classList.remove("hidden"); this.panel.classList.add("flex"); },
      close() { this.panel.classList.add("hidden"); this.panel.classList.remove("flex"); },
      reset(mode: string) {
        $("xp-capot-moteur").textContent = "…";
        $("xp-capot-latence").textContent = "…";
        $("xp-capot-frags").textContent = "0";
        $("xp-capot-modele").textContent = `requête « ${mode} » en cours…`;
        $("xp-capot-system").textContent = "—";
        $("xp-capot-flux").textContent = "";
      },
    };
    $("xp-capot-open").addEventListener("click", () => capot.open());
    $("xp-capot-close").addEventListener("click", () => capot.close());

    type Handlers = { meta?: (d: any) => void; delta?: (d: any) => void; done?: (d: any) => void; error?: (d: any) => void; etape?: (d: any) => void; skill?: (d: any) => void; audit?: (d: any) => void };

    // URL du site du visiteur, mémorisée après une analyse réussie :
    // le générateur métier et l'assistant s'en servent comme contexte.
    let siteUrlActive: string | null = null;

    async function streamIA(mode: string, messages: { role: string; content: string }[], h: Handlers) {
      capot.reset(mode);
      let frags = 0;
      const flux = $("xp-capot-flux");
      const res = await fetch("/api/experience", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ mode, messages, siteUrl: siteUrlActive ?? undefined }),
      });
      if (!res.ok || !res.body) throw new Error(`API ${res.status}`);
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = "";
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });
        const blocs = buffer.split("\n\n");
        buffer = blocs.pop() ?? "";
        for (const bloc of blocs) {
          let event = "message", data = "";
          for (const line of bloc.split("\n")) {
            if (line.startsWith("event: ")) event = line.slice(7);
            else if (line.startsWith("data: ")) data += line.slice(6);
          }
          if (!data) continue;
          const parsed = JSON.parse(data);
          if (event === "meta") {
            $("xp-capot-moteur").textContent = parsed.engine;
            $("xp-capot-modele").textContent = parsed.model + (parsed.source ? ` · source lue : ${new URL(parsed.source.url).hostname}` : "");
            $("xp-capot-system").textContent = parsed.system + "…";
          } else if (event === "etape") {
            $("xp-capot-modele").textContent = parsed.label;
          } else if (event === "delta") {
            frags += 1;
            $("xp-capot-frags").textContent = String(frags);
            flux.append(parsed.text);
            flux.scrollTop = flux.scrollHeight;
          } else if (event === "done") {
            $("xp-capot-latence").textContent = `${parsed.ms} ms`;
          }
          (h as any)[event]?.(parsed);
        }
      }
    }

    /* ————— Console du hero : état réel du moteur ————— */
    const consoleEl = $("xp-console");
    (async () => {
      const steps = ["initialisation…", "connexion au moteur IA…"];
      for (const s of steps) {
        consoleEl.textContent = s;
        if (!reduced) await new Promise((r) => setTimeout(r, 550));
      }
      try {
        const res = await fetch("/api/experience");
        const info = await res.json();
        if (info.ok) {
          consoleEl.textContent = `moteur ${info.engine} en ligne — à vous de jouer.`;
        } else {
          throw new Error("aucun moteur");
        }
      } catch {
        consoleEl.textContent = "démonstration hors ligne — la page reste visitable.";
        $("xp-led").classList.replace("bg-lime", "bg-white/40");
        $("xp-led-ping").classList.add("hidden");
      }
    })();

    /* ————— Acte 1 : radar animé (profil de présence en ligne) ————— */
    const AXES = [
      { skill: "performance", label: "Performance" },
      { skill: "seo", label: "Référencement" },
      { skill: "reseaux", label: "Réseaux" },
      { skill: "decouvrabilite", label: "Découvrabilité" },
      { skill: "aeo", label: "Lisibilité IA" },
    ];
    const radar = $("xp-radar") as HTMLCanvasElement;
    const rctx = radar.getContext("2d")!;
    const radarVal: Record<string, number> = {}; // valeur affichée (animée)
    const radarCible: Record<string, number> = {}; // valeur mesurée
    AXES.forEach((a) => { radarVal[a.skill] = 0; radarCible[a.skill] = 0; });

    function dessinerRadar() {
      const W = radar.width, H = radar.height;
      const cx = W / 2, cy = H / 2 + 8, R = Math.min(W, H) / 2 - 92;
      rctx.clearRect(0, 0, W, H);
      const pt = (i: number, v: number) => {
        const ang = -Math.PI / 2 + (i * 2 * Math.PI) / AXES.length;
        return [cx + Math.cos(ang) * R * (v / 100), cy + Math.sin(ang) * R * (v / 100)];
      };
      // Grille discrète : anneaux 25/50/75/100 + rayons
      rctx.strokeStyle = "rgba(255,255,255,0.10)";
      rctx.lineWidth = 1;
      for (const niveau of [25, 50, 75, 100]) {
        rctx.beginPath();
        AXES.forEach((_, i) => { const [x, y] = pt(i, niveau); i ? rctx.lineTo(x, y) : rctx.moveTo(x, y); });
        rctx.closePath(); rctx.stroke();
      }
      AXES.forEach((_, i) => { const [x, y] = pt(i, 100); rctx.beginPath(); rctx.moveTo(cx, cy); rctx.lineTo(x, y); rctx.stroke(); });
      // Série unique : contour lime 2px + remplissage translucide
      rctx.beginPath();
      AXES.forEach((a, i) => { const [x, y] = pt(i, radarVal[a.skill]); i ? rctx.lineTo(x, y) : rctx.moveTo(x, y); });
      rctx.closePath();
      rctx.fillStyle = "rgba(200,255,61,0.13)"; rctx.fill();
      rctx.strokeStyle = "#c8ff3d"; rctx.lineWidth = 2.5; rctx.stroke();
      AXES.forEach((a, i) => {
        const [x, y] = pt(i, radarVal[a.skill]);
        rctx.beginPath(); rctx.arc(x, y, 5, 0, Math.PI * 2);
        rctx.fillStyle = "#c8ff3d"; rctx.fill();
        rctx.beginPath(); rctx.arc(x, y, 7, 0, Math.PI * 2);
        rctx.strokeStyle = "#0a0a0a"; rctx.lineWidth = 2; rctx.stroke();
      });
      // Étiquettes d'axes (encre, jamais la couleur de série) + score
      rctx.font = "22px Geist, system-ui, sans-serif";
      rctx.textAlign = "center";
      AXES.forEach((a, i) => {
        const [x, y] = pt(i, 121);
        rctx.fillStyle = "rgba(255,255,255,0.6)";
        rctx.fillText(a.label, x, y);
        if (radarCible[a.skill] > 0) {
          rctx.fillStyle = "rgba(255,255,255,0.92)";
          rctx.font = "600 22px Geist, system-ui, sans-serif";
          rctx.fillText(String(Math.round(radarVal[a.skill])), x, y + 26);
          rctx.font = "22px Geist, system-ui, sans-serif";
        }
      });
    }
    let radarAnime = false;
    function animerRadar() {
      if (radarAnime) return;
      radarAnime = true;
      const pas = () => {
        let reste = false;
        for (const a of AXES) {
          const d = radarCible[a.skill] - radarVal[a.skill];
          if (Math.abs(d) > 0.5) { radarVal[a.skill] += d * (reduced ? 1 : 0.09); reste = true; }
          else radarVal[a.skill] = radarCible[a.skill];
        }
        dessinerRadar();
        if (reste) requestAnimationFrame(pas);
        else radarAnime = false;
      };
      requestAnimationFrame(pas);
    }
    dessinerRadar();

    /** Compteur animé pour les tuiles de mesures. */
    function animerValeur(id: string, cible: number) {
      const el = $(id);
      if (reduced) { el.textContent = String(cible); return; }
      const t0 = performance.now();
      const pas = (t: number) => {
        const k = Math.min((t - t0) / 1200, 1);
        el.textContent = String(Math.round(cible * (1 - Math.pow(1 - k, 3))));
        if (k < 1) requestAnimationFrame(pas);
      };
      requestAnimationFrame(pas);
    }

    /** Ajoute la ligne d'un skill dans le terminal d'audit. */
    function afficherSkill(r: { skill: string; label: string; score: number; mesures: { label: string; valeur: string; ok: boolean }[] }) {
      const ligne = document.createElement("div");
      ligne.className = "xp-slide-in border-b border-white/8 pb-3 last:border-b-0";
      ligne.innerHTML =
        `<div class="flex items-baseline justify-between gap-3">
           <span class="text-lime">▸ ${r.label}</span>
           <span class="text-white/90">${r.score}<span class="text-white/40">/100</span></span>
         </div>
         <div class="mt-1.5 leading-relaxed text-white/50">` +
        r.mesures.map((m) => `${m.label} ${m.valeur} <span class="${m.ok ? "text-lime" : "text-white/35"}">${m.ok ? "✓" : "✗"}</span>`).join(" · ") +
        `</div>`;
      $("xp-skills").append(ligne);
      radarCible[r.skill] = r.score;
      animerRadar();
    }

    /* ————— Acte 1 : analyse du site du visiteur ————— */
    let analyseEnCours = false;
    $("xp-url-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const brut = ($("xp-url-input") as HTMLInputElement).value.trim();
      if (!brut || analyseEnCours) return;
      analyseEnCours = true;
      const go = $("xp-url-go") as HTMLButtonElement;
      const box = $("xp-analyse-box") as HTMLElement;
      const texte = $("xp-analyse-texte");
      const setStatut = (t: string) => { $("xp-analyse-statut").textContent = t; $("xp-analyse-statut2").textContent = t; };
      go.disabled = true;
      box.style.opacity = "1";
      $("xp-analyse").scrollIntoView({ behavior: reduced ? "auto" : "smooth" });
      // Remise à zéro du tableau de bord
      $("xp-skills").innerHTML = "";
      AXES.forEach((a) => { radarCible[a.skill] = 0; radarVal[a.skill] = 0; });
      dessinerRadar();
      for (const id of ["xp-t-ttfb", "xp-t-poids", "xp-t-jsonld", "xp-t-alt"]) $(id).textContent = "—";
      texte.textContent = "";
      texte.classList.add("xp-encours");
      setStatut("lecture du site…");
      $("xp-analyse-source").classList.add("hidden");
      $("xp-analyse-cta").classList.add("hidden");
      siteUrlActive = brut;
      let ok = false;
      try {
        await streamIA("analyse", [{ role: "user", content: "Analyse mon entreprise à partir du contenu de son site." }], {
          etape: (d) => { setStatut(d.label); consoleEl.textContent = d.label; },
          skill: (d) => afficherSkill(d),
          audit: (d) => {
            animerValeur("xp-t-ttfb", d.tuiles.ttfbMs);
            animerValeur("xp-t-poids", d.tuiles.poidsKo);
            animerValeur("xp-t-jsonld", d.tuiles.jsonLd);
            if (d.tuiles.altPct === null) $("xp-t-alt").textContent = "—";
            else animerValeur("xp-t-alt", d.tuiles.altPct);
          },
          meta: (d) => {
            setStatut(`${d.engine} · en direct`);
            if (d.source) {
              siteUrlActive = d.source.url;
              $("xp-analyse-domaine").textContent = new URL(d.source.url).hostname + (d.source.titre ? ` — « ${d.source.titre} »` : "");
              $("xp-analyse-source").classList.remove("hidden");
              $("xp-analyse-source").classList.add("flex");
            }
          },
          delta: (d) => { texte.append(d.text); ok = true; },
          error: (d) => { texte.textContent = d.message; setStatut("échec de lecture"); siteUrlActive = null; },
          done: (d) => { if (ok) setStatut(`mesuré et rédigé en ${(d.ms / 1000).toFixed(1)} s`); },
        });
      } catch {
        texte.textContent = "La démonstration IA est momentanément indisponible — réessayez dans un instant.";
        setStatut("hors ligne");
        siteUrlActive = null;
      }
      texte.classList.remove("xp-encours");
      if (ok) {
        $("xp-analyse-cta").classList.remove("hidden");
        consoleEl.textContent = "site audité — la page est désormais calée sur votre entreprise.";
      }
      go.disabled = false;
      analyseEnCours = false;
    });

    /* ————— Acte 2 : quiz ————— */
    const QUIZ: { q: string; options: string[]; cle: string }[] = JSON.parse($("xp-quiz-data").textContent!);
    let quizIndex = 0;
    const quizReponses: { cle: string; valeur: string }[] = [];

    const renderQuestion = () => {
      const item = QUIZ[quizIndex];
      $("xp-quiz-num").textContent = String(quizIndex + 1).padStart(2, "0");
      ($("xp-quiz-bar") as HTMLElement).style.width = `${(quizIndex / QUIZ.length) * 100}%`;
      $("xp-quiz-q").textContent = item.q;
      const opts = $("xp-quiz-opts");
      opts.innerHTML = "";
      for (const option of item.options) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "xp-opt";
        btn.textContent = option;
        btn.addEventListener("click", () => choisir(option));
        opts.append(btn);
      }
      $("xp-quiz-slide").classList.add("xp-slide-in");
      setTimeout(() => $("xp-quiz-slide").classList.remove("xp-slide-in"), 400);
    };

    const choisir = (valeur: string) => {
      quizReponses.push({ cle: QUIZ[quizIndex].cle, valeur });
      quizIndex += 1;
      if (quizIndex < QUIZ.length) {
        const slide = $("xp-quiz-slide");
        slide.classList.add("xp-slide-out");
        setTimeout(() => { slide.classList.remove("xp-slide-out"); renderQuestion(); }, reduced ? 0 : 260);
      } else {
        ($("xp-quiz-bar") as HTMLElement).style.width = "100%";
        $("xp-quiz-slide").classList.add("hidden");
        $("xp-quiz-recap").classList.remove("hidden");
        $("xp-quiz-recap-liste").innerHTML = quizReponses
          .map((r) => `<li class="flex gap-2"><span class="text-lime">+</span><span>${r.cle} : ${r.valeur}</span></li>`)
          .join("");
        lancerVerdict();
      }
    };

    const lancerVerdict = async () => {
      const box = $("xp-verdict-box");
      const texte = $("xp-verdict-texte");
      const statut = $("xp-verdict-statut");
      box.style.opacity = "1";
      texte.textContent = "";
      texte.classList.add("xp-encours");
      statut.textContent = "le modèle rédige…";
      box.scrollIntoView({ behavior: reduced ? "auto" : "smooth", block: "nearest" });
      const recap = quizReponses.map((r, i) => `${i + 1}. ${r.cle} : ${r.valeur}`).join("\n");
      try {
        await streamIA("quiz", [{ role: "user", content: `Mes réponses au diagnostic :\n${recap}` }], {
          meta: (d) => { statut.textContent = `${d.engine} · en direct`; },
          delta: (d) => { texte.append(d.text); },
          error: (d) => { texte.textContent = d.message; },
          done: (d) => { statut.textContent = `généré en ${(d.ms / 1000).toFixed(1)} s`; },
        });
      } catch {
        texte.textContent = "La démonstration IA est momentanément indisponible — réessayez dans un instant.";
        statut.textContent = "hors ligne";
      }
      texte.classList.remove("xp-encours");
      $("xp-verdict-cta").classList.remove("hidden");
    };

    $("xp-quiz-restart").addEventListener("click", () => {
      quizIndex = 0;
      quizReponses.length = 0;
      $("xp-quiz-recap").classList.add("hidden");
      $("xp-quiz-slide").classList.remove("hidden");
      $("xp-verdict-cta").classList.add("hidden");
      ($("xp-verdict-box") as HTMLElement).style.opacity = "0.5";
      $("xp-verdict-texte").textContent = "Répondez aux cinq questions : le diagnostic s'écrira ici, mot à mot, pendant que le modèle réfléchit.";
      $("xp-verdict-statut").textContent = "en attente de vos réponses";
      renderQuestion();
    });

    renderQuestion();

    /* ————— Acte 3 : générateur sectoriel ————— */
    let secteurEnCours = false;
    const genererSecteur = async (secteur: string) => {
      if (secteurEnCours || !secteur.trim()) return;
      secteurEnCours = true;
      const go = $("xp-secteur-go") as HTMLButtonElement;
      const texte = $("xp-secteur-texte");
      const statut = $("xp-secteur-statut");
      go.disabled = true;
      $("xp-secteur-tag").textContent = secteur.toLowerCase();
      texte.textContent = "";
      texte.classList.add("xp-encours");
      statut.textContent = "génération…";
      try {
        await streamIA("secteur", [{ role: "user", content: `Mon métier / secteur : ${secteur}` }], {
          meta: (d) => { statut.textContent = `${d.engine} · en direct`; },
          delta: (d) => { texte.append(d.text); },
          error: (d) => { texte.textContent = d.message; },
          done: (d) => { statut.textContent = `généré en ${(d.ms / 1000).toFixed(1)} s`; },
        });
      } catch {
        texte.textContent = "La démonstration IA est momentanément indisponible — réessayez dans un instant.";
        statut.textContent = "hors ligne";
      }
      texte.classList.remove("xp-encours");
      go.disabled = false;
      secteurEnCours = false;
    };

    $("xp-secteur-form").addEventListener("submit", (e) => {
      e.preventDefault();
      genererSecteur(($("xp-secteur-input") as HTMLInputElement).value);
    });
    document.querySelectorAll<HTMLElement>(".xp-secteur-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        ($("xp-secteur-input") as HTMLInputElement).value = chip.dataset.secteur!;
        genererSecteur(chip.dataset.secteur!);
      });
    });

    /* ————— Acte 4 : assistant de qualification ————— */
    const chatMessages: { role: "user" | "assistant"; content: string }[] = [];
    let chatEnCours = false;
    const chatLog = $("xp-chat-log");
    const chatInput = $("xp-chat-input") as HTMLInputElement;
    const chatGo = $("xp-chat-go") as HTMLButtonElement;

    const bulle = (classe: string) => {
      const div = document.createElement("div");
      div.className = classe;
      chatLog.append(div);
      chatLog.scrollTop = chatLog.scrollHeight;
      return div;
    };

    $("xp-chat-form").addEventListener("submit", async (e) => {
      e.preventDefault();
      const contenu = chatInput.value.trim();
      if (!contenu || chatEnCours) return;
      chatEnCours = true;
      chatInput.value = "";
      chatInput.disabled = true;
      chatGo.disabled = true;

      bulle("xp-bulle-moi").textContent = contenu;
      chatMessages.push({ role: "user", content: contenu });

      const reponse = bulle("xp-bulle-ia max-w-[85%] rounded-2xl rounded-tl-md border border-lime/20 bg-lime/[0.06] px-4 py-3 text-[14px] leading-relaxed text-white/85 xp-encours");
      let texteIA = "";
      try {
        await streamIA("bot", chatMessages, {
          delta: (d) => { texteIA += d.text; reponse.textContent = texteIA; chatLog.scrollTop = chatLog.scrollHeight; },
          error: (d) => { texteIA = d.message; reponse.textContent = texteIA; },
        });
      } catch {
        texteIA = "La démonstration IA est momentanément indisponible — réessayez dans un instant.";
        reponse.textContent = texteIA;
      }
      reponse.classList.remove("xp-encours");
      if (texteIA) chatMessages.push({ role: "assistant", content: texteIA });

      // Garde-fou : au-delà de 6 échanges, on passe le relais au vrai rendez-vous.
      if (chatMessages.filter((m) => m.role === "user").length >= 6) {
        chatInput.placeholder = "La suite se passe de vive voix — réservez l'audit ↓";
        chatInput.disabled = true;
        chatGo.disabled = true;
      } else {
        chatInput.disabled = false;
        chatGo.disabled = false;
        chatInput.focus();
      }
      chatEnCours = false;
    });

    /* ————— Mode blueprint ————— */
    $("xp-blueprint").addEventListener("click", () => {
      const on = document.documentElement.classList.toggle("xp-reveal");
      $("xp-blueprint").setAttribute("aria-pressed", String(on));
      $("xp-blueprint").textContent = on ? "[ masquer la structure ]" : "[ révéler la structure ]";
    });
  </script>

  <script type="application/json" id="xp-quiz-data" set:html={JSON.stringify(QUIZ)} />
</BaseLayout>
