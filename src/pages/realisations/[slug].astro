---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import MethodeFlow from "@/components/MethodeFlow.astro";
import AssistantsSchema from "@/components/AssistantsSchema.astro";
import CtaButton from "@/components/CtaButton.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/lib/site";

export async function getStaticPaths() {
  const realisations = await getCollection("realisations", ({ data }) => data.published);
  return realisations.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const hasBody = (entry.body ?? "").trim().length > 0;
const canonical = `${SITE.url}/realisations/${entry.id}`;

// Meta description : pitch tronqué proprement à ~158 caractères (frontière de mot).
const metaDescription =
  d.pitch.length > 160 ? d.pitch.slice(0, 158).replace(/\s+\S*$/, "") + "…" : d.pitch;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: d.title,
    description: metaDescription,
    url: canonical,
    datePublished: `${d.annee}-01-01`,
    inLanguage: "fr",
    author: { "@id": `${SITE.url}/#julien-tridat` },
    about: d.stack,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: `${SITE.url}/` },
      { "@type": "ListItem", position: 2, name: "Cas clients", item: `${SITE.url}/realisations` },
      { "@type": "ListItem", position: 3, name: d.title, item: canonical },
    ],
  },
];
---

<BaseLayout title={`${d.title} | Julien Tridat`} description={metaDescription} canonical={canonical} ogType="article" jsonLd={jsonLd}>
  <main class="bg-background text-foreground">
    <header class="relative border-b border-white/10 px-6 pb-16 pt-36 md:px-12 md:pb-20 md:pt-44">
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background: radial-gradient(700px 400px at 20% 0%, oklch(0.92 0.21 125 / 0.07), transparent 70%);"
      >
      </div>
      <Nav />
      <div class="mx-auto max-w-4xl">
        <nav class="mb-8 text-sm text-white/50" aria-label="Fil d'Ariane">
          <a href="/" class="hover:text-white">Accueil</a>
          <span class="mx-2 text-white/30">/</span>
          <a href="/realisations" class="hover:text-white">Cas clients</a>
        </nav>
        <Eyebrow>{d.client} · {d.secteur} · {d.annee}</Eyebrow>
        <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-light leading-[1.05] tracking-[-0.03em]">
          {d.title}
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-white/70">{d.pitch}</p>
        <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
          <div>
            <span class="text-white/45">Rôle — </span>
            <span class="text-white/85">{d.role}</span>
          </div>
          {d.stack.length > 0 && (
            <div class="flex flex-wrap items-center gap-2">
              {d.stack.map((s) => (
                <span class="rounded-full border border-lime/40 bg-lime/5 px-3 py-1 text-xs text-lime">{s}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </header>

    {(d.enjeu || d.transformation) && (
      <section class="border-b border-white/10 px-6 py-14 md:px-12 md:py-16">
        <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-[1fr_auto_1fr] md:items-center">
          <div>
            <div class="text-[11px] uppercase tracking-[0.22em] text-white/40">Avant — l'enjeu</div>
            <p class="mt-3 text-lg leading-relaxed text-white/65">{d.enjeu}</p>
          </div>
          <div class="hidden text-3xl text-lime md:block" aria-hidden="true">→</div>
          <div>
            <div class="text-[11px] uppercase tracking-[0.22em] text-lime">Après — la transformation</div>
            <p class="mt-3 text-lg leading-relaxed text-white">{d.transformation}</p>
          </div>
        </div>
      </section>
    )}

    {d.resultats.length > 0 && (
      <section class="border-b border-white/10 bg-[oklch(0.17_0_0)] px-6 py-12 md:px-12">
        <div class="mx-auto flex max-w-4xl flex-wrap gap-x-14 gap-y-6">
          {d.resultats.map((res) => (
            <div>
              <div class="text-4xl font-light text-lime">{res.chiffre}</div>
              <div class="mt-2 max-w-[11rem] text-[11px] uppercase tracking-wider text-white/55">
                {res.label}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {d.pointDepart && (
      <section class="px-6 py-16 md:px-12 md:py-20">
        <div class="mx-auto max-w-3xl">
          <Eyebrow>Le point de départ</Eyebrow>
          <p class="text-xl font-light leading-relaxed text-white/85">{d.pointDepart}</p>
        </div>
      </section>
    )}

    {d.methode.length > 0 && (
      <section class="border-t border-white/10 px-6 py-16 md:px-12 md:py-20">
        <div class="mx-auto max-w-4xl">
          <Eyebrow>La méthode, sur le terrain</Eyebrow>
          <MethodeFlow etapes={d.methode} />
        </div>
      </section>
    )}

    {d.assistants.length > 0 && (
      <section class="border-t border-white/10 bg-[oklch(0.17_0_0)] px-6 py-16 md:px-12 md:py-20">
        <div class="mx-auto max-w-4xl">
          <Eyebrow>Les assistants installés</Eyebrow>
          <p class="mb-8 max-w-2xl text-[15px] leading-relaxed text-white/60">
            Pas des démonstrations : des systèmes qui tournent dans leurs outils, des mois après.
          </p>
          <AssistantsSchema assistants={d.assistants} />
        </div>
      </section>
    )}

    {d.bilan && (
      <section class="border-t border-white/10 px-6 py-16 md:px-12 md:py-20">
        <div class="mx-auto max-w-3xl">
          <Eyebrow>Ce qui a changé</Eyebrow>
          <p class="text-xl font-light leading-relaxed text-white/85">{d.bilan}</p>
        </div>
      </section>
    )}

    {hasBody && (
      <article class="border-t border-white/10 px-6 py-16 md:px-12 md:py-20">
        <div class="prose-artefact mx-auto max-w-3xl">
          <Content />
        </div>
      </article>
    )}

    {d.visuel && (
      <section class="border-t border-white/10 px-6 py-12 md:px-12">
        <figure class="mx-auto max-w-3xl">
          <figcaption class="mb-4 text-[11px] uppercase tracking-[0.2em] text-white/40">
            Un aperçu — pour la preuve, pas pour la démonstration
          </figcaption>
          <div class="overflow-hidden rounded-xl border border-white/10">
            {d.demo ? (
              <a href={d.demo.url} target="_blank" rel="noopener" class="block">
                <img src={d.visuel.src} alt={d.visuel.alt} width="1200" height="675" loading="lazy" class="w-full opacity-75 transition-opacity hover:opacity-100" />
              </a>
            ) : (
              <img src={d.visuel.src} alt={d.visuel.alt} width="1200" height="675" loading="lazy" class="w-full opacity-75" />
            )}
          </div>
          {d.demo && (
            <a href={d.demo.url} target="_blank" rel="noopener" class="mt-3 inline-flex items-center gap-1.5 text-[13px] text-white/50 hover:text-lime">
              {d.demo.label} <span>→</span>
            </a>
          )}
        </figure>
      </section>
    )}

    <section class="border-t border-white/10 px-6 py-16 md:px-12">
      <div class="mx-auto flex max-w-3xl flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
        <p class="max-w-md text-lg leading-relaxed text-white/75">
          Un contexte proche du vôtre ? <em class="text-lime">Parlons-en 30 minutes.</em>
        </p>
        <CtaButton>Réserver un audit</CtaButton>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
