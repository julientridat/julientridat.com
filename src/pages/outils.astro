---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/lib/site";

const outils = (await getCollection("outils", ({ data }) => data.published)).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
);

const typeColors: Record<string, string> = {
  Skill: "border-lime/40 bg-lime/5 text-lime",
  "Projet client": "border-sky-300/40 bg-sky-300/5 text-sky-300",
  Méthode: "border-amber-300/40 bg-amber-300/5 text-amber-300",
  Infrastructure: "border-white/30 bg-white/5 text-white/70",
};

const title = "Outils — les systèmes que je construis | Julien Tridat";
const description =
  "Skills, projets IA clients, méthodes et infrastructures : chaque système documenté — ce qu'il encode, ce qu'il produit, et une démo quand elle est testable.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Outils — Julien Tridat",
    description,
    url: `${SITE.url}/outils`,
    author: { "@id": `${SITE.url}/#julien-tridat` },
  },
];
---

<BaseLayout title={title} description={description} canonical={`${SITE.url}/outils`} jsonLd={jsonLd}>
  <main class="bg-background text-foreground">
    <header class="relative border-b border-white/10 px-6 pb-16 pt-36 md:px-12 md:pb-24 md:pt-44">
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background: radial-gradient(700px 400px at 20% 0%, oklch(0.92 0.21 125 / 0.07), transparent 70%);"
      >
      </div>
      <Nav />
      <div class="mx-auto max-w-7xl">
        <Eyebrow>Outils</Eyebrow>
        <h1 class="max-w-4xl text-[clamp(2.5rem,6vw,4.5rem)] font-light leading-[1.02] tracking-[-0.03em]">
          Je ne livre pas des conseils.
          <em class="text-lime">Je livre des systèmes.</em>
        </h1>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-white/70">
          Chaque mission produit un outil qui reste : un skill qui encode une charte ou une
          méthode, un projet IA calibré sur un métier, une infrastructure qui tourne sans moi.
          En voici le registre — <strong class="font-medium text-white">avec ce que chacun
          encode, ce qu'il produit, et une démo quand elle est testable.</strong>
        </p>
      </div>
    </header>

    <section class="px-6 py-16 md:px-12 md:py-24">
      <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-2 lg:grid-cols-3">
        {outils.map((o) => (
          <div class="flex flex-col rounded-2xl border border-white/15 p-7 transition-colors hover:border-white/30">
            <div class={`w-fit rounded-full border px-3 py-1 text-[11px] uppercase tracking-wider ${typeColors[o.data.type]}`}>
              {o.data.type}
            </div>
            <h2 class="mt-4 text-xl font-medium leading-snug">{o.data.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-white/70">{o.data.pitch}</p>

            {o.data.encode.length > 0 && (
              <div class="mt-5 border-t border-white/10 pt-4">
                <div class="text-[10px] uppercase tracking-[0.2em] text-white/45">Ce qu'il encode</div>
                <ul class="mt-2 space-y-1.5 text-[13px] text-white/70">
                  {o.data.encode.map((e) => (
                    <li class="flex gap-2"><span class="text-lime">—</span><span>{e}</span></li>
                  ))}
                </ul>
              </div>
            )}

            {o.data.sorties.length > 0 && (
              <div class="mt-4">
                <div class="text-[10px] uppercase tracking-[0.2em] text-white/45">Ce qu'il produit</div>
                <ul class="mt-2 space-y-1.5 text-[13px] text-white/70">
                  {o.data.sorties.map((s) => (
                    <li class="flex gap-2"><span class="text-lime">+</span><span>{s}</span></li>
                  ))}
                </ul>
              </div>
            )}

            <div class="mt-auto flex flex-wrap items-center gap-x-5 gap-y-3 pt-6">
              {o.data.demo && (
                <a
                  href={o.data.demo.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 rounded-full bg-lime px-4 py-2.5 text-[13px] font-medium text-black transition-colors hover:bg-lime/90"
                >
                  {o.data.demo.label} <span>→</span>
                </a>
              )}
              {o.data.caseUrl && (
                <a href={o.data.caseUrl} class="text-[13px] text-white/60 underline-offset-4 hover:text-lime hover:underline">
                  Étude de cas
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
