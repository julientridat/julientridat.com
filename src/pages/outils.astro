---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import Gains from "@/components/sections/Gains.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/lib/site";

const outils = (await getCollection("outils", ({ data }) => data.published)).sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
);

const groupes = [
  {
    id: "decider",
    titre: "Pour décider",
    intro:
      "Vous vous demandez où l'IA vous ferait vraiment gagner, ou comment parler à votre marché ? Ces outils transforment la question en réponse structurée.",
  },
  {
    id: "assistants",
    titre: "Des assistants dans vos outils",
    intro:
      "Des IA calibrées sur votre métier, vos règles et vos garde-fous — livrées prêtes à l'emploi, à votre équipe, dans les outils qu'elle utilise déjà.",
  },
  {
    id: "marketing",
    titre: "Pour produire votre marketing",
    intro:
      "Votre charte encodée une fois pour toutes : visuels, vignettes, présentations — conformes au pixel, produits à la demande, sans re-brief.",
  },
  {
    id: "operations",
    titre: "Pour vos opérations",
    intro:
      "Les tâches répétitives encodées : plannings, facturation, contrôle qualité, veille. Elles tournent, vous validez.",
  },
];

const typeColors: Record<string, string> = {
  Skill: "border-lime/40 bg-lime/5 text-lime",
  "Projet client": "border-sky-300/40 bg-sky-300/5 text-sky-300",
  Méthode: "border-amber-300/40 bg-amber-300/5 text-amber-300",
  Infrastructure: "border-white/30 bg-white/5 text-white/70",
};

const title = "Outils — les systèmes que je construis | Julien Tridat";
const description =
  "Skills, projets IA clients, méthodes et infrastructures, classés par besoin : décider, produire votre marketing, équiper vos équipes, fluidifier vos opérations.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Outils — Julien Tridat",
    description,
    url: `${SITE.url}/outils`,
    author: { "@id": `${SITE.url}/#julien-tridat` },
  },
];
---

<BaseLayout title={title} description={description} canonical={`${SITE.url}/outils`} jsonLd={jsonLd}>
  <main class="bg-background text-foreground">
    <header class="relative border-b border-white/10 px-6 pb-16 pt-36 md:px-12 md:pb-20 md:pt-44">
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background: radial-gradient(700px 400px at 20% 0%, oklch(0.92 0.21 125 / 0.07), transparent 70%);"
      >
      </div>
      <Nav />
      <div class="mx-auto max-w-7xl">
        <Eyebrow>Outils</Eyebrow>
        <h1 class="max-w-4xl text-[clamp(2.5rem,6vw,4.5rem)] font-light leading-[1.02] tracking-[-0.03em]">
          Je ne livre pas des conseils.
          <em class="text-lime">Je livre des systèmes.</em>
        </h1>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-white/70">
          Chaque mission produit un outil qui reste et travaille après mon départ. En voici le
          registre, classé par ce qu'il change <strong class="font-medium text-white">pour vous</strong> —
          avec une démo quand c'est testable.
        </p>
        <nav class="mt-8 flex flex-wrap gap-2" aria-label="Aller à un besoin">
          {groupes.map((g) => (
            <a
              href={`#${g.id}`}
              class="rounded-full border border-white/20 px-4 py-2 text-[13px] text-white/70 transition-colors hover:border-lime hover:text-lime"
            >
              {g.titre}
            </a>
          ))}
        </nav>
      </div>
    </header>

    {groupes.map((g) => {
      const items = outils.filter((o) => o.data.besoin === g.id);
      if (items.length === 0) return null;
      return (
        <section id={g.id} class="scroll-mt-24 border-b border-white/10 px-6 py-14 md:px-12 md:py-20">
          <div class="mx-auto max-w-7xl">
            <h2 class="text-[clamp(1.5rem,3vw,2.2rem)] font-light leading-tight tracking-[-0.02em]">
              {g.titre}<span class="text-lime">.</span>
            </h2>
            <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-white/60">{g.intro}</p>
            <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
              {items.map((o) => (
                <div class="flex flex-col rounded-2xl border border-white/12 bg-white/[0.02] p-6 transition-colors hover:border-white/25">
                  <div class={`w-fit rounded-full border px-3 py-1 text-[10px] uppercase tracking-wider ${typeColors[o.data.type]}`}>
                    {o.data.type}
                  </div>
                  <h3 class="mt-3.5 text-[17px] font-medium leading-snug">{o.data.title}</h3>
                  <p class="mt-2 text-[13.5px] leading-relaxed text-white/55">{o.data.pitch}</p>

                  {o.data.gain && (
                    <div class="mt-4 flex flex-wrap items-baseline gap-x-2 gap-y-1 rounded-lg bg-lime/[0.06] px-3 py-2 text-[12.5px]">
                      <span class="text-white/60">{o.data.gain.tache} :</span>
                      <span class="text-white/40 line-through decoration-white/25">{o.data.gain.avant}</span>
                      <span class="text-lime">→ {o.data.gain.apres}</span>
                    </div>
                  )}

                  {(o.data.encode.length > 0 || o.data.sorties.length > 0) && (
                    <details class="group/d mt-4">
                      <summary class="cursor-pointer list-none text-[12px] text-white/45 transition-colors hover:text-lime">
                        <span class="inline-block transition-transform group-open/d:rotate-90">›</span>
                        Ce qu'il encode, ce qu'il produit
                      </summary>
                      <div class="mt-3 space-y-3 border-l border-white/10 pl-4">
                        <ul class="space-y-1.5 text-[12.5px] text-white/60">
                          {o.data.encode.map((e) => (
                            <li class="flex gap-2"><span class="text-lime">—</span><span>{e}</span></li>
                          ))}
                          {o.data.sorties.map((s) => (
                            <li class="flex gap-2"><span class="text-lime">+</span><span>{s}</span></li>
                          ))}
                        </ul>
                      </div>
                    </details>
                  )}

                  <div class="mt-auto flex flex-wrap items-center gap-x-4 gap-y-2 pt-5">
                    {o.data.demo && (
                      <a
                        href={o.data.demo.url}
                        target="_blank"
                        rel="noopener"
                        class="inline-flex items-center gap-2 rounded-full bg-lime px-4 py-2 text-[12.5px] font-medium text-black transition-colors hover:bg-lime/90"
                      >
                        {o.data.demo.label} <span>→</span>
                      </a>
                    )}
                    {o.data.caseUrl && (
                      <a href={o.data.caseUrl} class="text-[12.5px] text-white/55 underline-offset-4 hover:text-lime hover:underline">
                        Étude de cas
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      );
    })}

    <Gains bg />

    <Footer />
  </main>
</BaseLayout>
