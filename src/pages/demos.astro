---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/lib/site";

const demos = [
  {
    url: "/demos/deck-formation/",
    visuel: "/artefacts/deck-formation.webp",
    titre: "Support de formation IA & Texte",
    nature: "Artefact réel, anonymisé",
    desc: "Le support complet d'une journée de formation livrée à une agence santé — 38 écrans navigables. Seul le nom du client a été remplacé (« Horizon », agence fictive) : le contenu, la pédagogie et le design sont ceux de la mission.",
    caseUrl: "/realisations/formation-ia-agence-sante",
    action: "Parcourir le support",
  },
  {
    url: "/demos/support-groupe-retail.html",
    visuel: "/artefacts/support-groupe-retail.webp",
    titre: "Support scrollytelling — groupe retail",
    nature: "Artefact réel, anonymisé",
    desc: "Le support de formation one-page livré pour un groupe international de travel retail, à la charte rouge de l'organisme partenaire : scrollytelling, nav sticky, fil des « 5 verbes ». Groupe et organisme remplacés par des noms fictifs.",
    caseUrl: "/realisations/formation-groupe-travel-retail",
    action: "Dérouler le support",
  },
  {
    url: "/demos/restitution-agence-creative.html",
    visuel: "/artefacts/restitution-agence-creative.webp",
    titre: "Restitution d'audit — la vraie",
    nature: "Artefact réel, anonymisé",
    desc: "Le deck de restitution réellement présenté à la direction d'une agence créative — 16 slides blanc/bleu : synthèse des entretiens terrain, diagnostic, recommandations. L'agence (« Kaleido ») est un nom fictif, tout le reste est le livrable.",
    caseUrl: "/realisations/agents-agence-creative",
    action: "Parcourir la restitution",
  },
  {
    url: "/demos/feuille-de-route-enseigne.html",
    visuel: "/artefacts/feuille-de-route-enseigne.webp",
    titre: "Feuille de route post-formation",
    nature: "Artefact réel, anonymisé",
    desc: "Le livrable envoyé après une matinée d'acculturation à l'équipe marketing d'une enseigne nationale : cartographie d'assistants pôle par pôle, priorités, méthode « fiche entreprise en 30 minutes ». Enseigne et prénoms anonymisés.",
    caseUrl: "/realisations/acculturation-enseigne-nationale",
    action: "Ouvrir la feuille de route",
  },
  {
    url: "/demos/guide-claude-clickup.html",
    visuel: "/artefacts/guide-claude-clickup.webp",
    titre: "Guide d'autonomie Claude × ClickUp",
    nature: "Artefact réel, anonymisé",
    desc: "Le guide d'auto-formation en 6 niveaux progressifs livré à un organisme de formation : à chaque palier, le prompt à copier, le résultat attendu, le piège à éviter. Le principe d'un livrable qui rend autonome — pas dépendant.",
    caseUrl: "/realisations/transformation-ia-organisme-formation",
    action: "Parcourir le guide",
  },
  {
    url: "/demos/formation-association.html",
    visuel: "/artefacts/formation-association.webp",
    titre: "Formation ChatGPT — bénévoles",
    nature: "Artefact réel, anonymisé",
    desc: "Le support interactif en 11 parties d'une formation pour bénévoles associatifs, avec les 3 Projets ChatGPT livrés clés en main et le plan d'ancrage sur 3 semaines. L'association (« Les Éclaireurs ») est un nom fictif.",
    caseUrl: "/realisations/association-benevoles-autonome",
    action: "Parcourir le support",
  },
  {
    url: "/demos/keynote-dirigeant.html",
    visuel: "/artefacts/keynote-dirigeant.webp",
    titre: "Keynote « Le dirigeant augmenté »",
    nature: "Artefact réel — donnée sur scène",
    desc: "La keynote réellement donnée devant un réseau de dirigeants le 30 juin 2026, dans sa version resserrée une heure avant de monter sur scène : 12 slides plein écran, un message par slide, notes d'intervenant incluses.",
    caseUrl: "/realisations/keynotes-dirigeants",
    action: "Dérouler la keynote",
  },
  {
    url: "/demos/skill-icp.html",
    visuel: "/artefacts/skill-icp.webp",
    titre: "Skill « Matrice ICP » — testable",
    nature: "Skill en démonstration",
    desc: "La méthode des 4 quadrants (peurs, freins, manques, handicaps) sur deux axes — sans l'offre, avec l'offre. Trois profils pré-calculés pour voir la profondeur de sortie : matrice complète, axes marketing, wording prêt à l'emploi.",
    caseUrl: null,
    action: "Tester le skill",
  },
  {
    url: "/demos/audit-flash.html",
    visuel: "/artefacts/audit-flash.webp",
    titre: "Grille d'audit flash IA — testable",
    nature: "Méthode interactive",
    desc: "L'outil de scoring de la session stratégique dirigeant, en version testable : notez une de vos tâches sur 5 critères, le verdict tombe en direct — automatiser maintenant, lever un verrou d'abord, ou garder l'humain.",
    caseUrl: null,
    action: "Scorer une de vos tâches",
  },
  {
    url: "/demos/etude-marche.html",
    visuel: "/artefacts/etude-marche.webp",
    titre: "Étude de marché scorée — doc stratégique",
    nature: "Extrait reconstitué d'un document réel",
    desc: "Le format des documents stratégiques livrés : grille de scoring pondérée, trois segments évalués, verdict argumenté, seuil de rentabilité. Extraits reconstitués d'une étude réelle — l'organisme (« Cap Forma ») est fictif.",
    caseUrl: "/realisations/offre-formation-ia-qualiopi",
    action: "Lire l'extrait",
  },
  {
    url: "/demos/vignettes-linkedin.html",
    visuel: "/artefacts/vignettes-linkedin.webp",
    titre: "Système de vignettes LinkedIn",
    nature: "Système réel, marque fictive",
    desc: "Trois gabarits éditoriaux chartés — chiffre choc, carte citation, triptyque de preuve — que l'assistant décline en série de campagne. La marque « KOMPA » est fictive, la mécanique est celle livrée en mission.",
    caseUrl: null,
    action: "Voir les 3 gabarits",
  },
  {
    url: "/demos/visuels-marque.html",
    visuel: "/artefacts/visuels-marque.webp",
    titre: "Configurateur de visuels chartés",
    nature: "Système réel, marque fictive",
    desc: "Le principe du design system livré à une franchise fitness : la charte encodée en gabarit HTML, le contenu injecté à la demande. Changez le club, le gabarit, le format, le titre — le visuel se re-rend au pixel. En mission, un assistant IA pilote ce gabarit en langage naturel.",
    caseUrl: "/realisations/design-system-franchise-fitness",
    action: "Tester le configurateur",
  },
  {
    url: "/demos/restitution-audit.html",
    visuel: "/artefacts/restitution-audit.webp",
    titre: "Restitution de cartographie IA",
    nature: "Méthode réelle, données fictives",
    desc: "Extrait du livrable de restitution d'un audit IA : carte des frictions, qualification production/jugement, matrice effort × impact, feuille de route en vagues. L'agence « Méridien » et ses chiffres sont fictifs ; la structure est celle des missions réelles.",
    caseUrl: "/realisations/cartographie-ia-agence",
    action: "Parcourir la restitution",
  },
  {
    url: "/demos/dashboard.html",
    visuel: "/artefacts/dashboard.webp",
    titre: "Dashboard narratif",
    nature: "Démo — données fictives",
    desc: "Un exemple du cas d'usage « assistant reporting » : les chiffres racontés avant d'être affichés. Le narratif du mois, les indicateurs et les signaux (comptes à réactiver) sont produits par l'assistant puis validés par un humain. Naviguez entre les mois.",
    caseUrl: null,
    action: "Ouvrir le dashboard",
  },
];

const title = "Démos — testez les systèmes | Julien Tridat";
const description =
  "Des artefacts à manipuler, pas des promesses : support de formation réel anonymisé, configurateur de visuels chartés, restitution d'audit IA, dashboard narratif.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Démos — Julien Tridat",
    description,
    url: `${SITE.url}/demos`,
    author: { "@id": `${SITE.url}/#julien-tridat` },
  },
];
---

<BaseLayout title={title} description={description} canonical={`${SITE.url}/demos`} jsonLd={jsonLd}>
  <main class="bg-background text-foreground">
    <header class="relative border-b border-white/10 px-6 pb-16 pt-36 md:px-12 md:pb-24 md:pt-44">
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background: radial-gradient(700px 400px at 20% 0%, oklch(0.92 0.21 125 / 0.07), transparent 70%);"
      >
      </div>
      <Nav />
      <div class="mx-auto max-w-7xl">
        <Eyebrow>Démos</Eyebrow>
        <h1 class="max-w-4xl text-[clamp(2.5rem,6vw,4.5rem)] font-light leading-[1.02] tracking-[-0.03em]">
          Ne me croyez pas. <em class="text-lime">Testez.</em>
        </h1>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-white/70">
          Des artefacts à manipuler, dans votre navigateur. Chacun est étiqueté honnêtement :
          <strong class="font-medium text-white">réel anonymisé</strong> quand c'est un livrable
          de mission dont seul le client a été masqué, <strong class="font-medium text-white">données
          fictives</strong> quand le système est réel mais la matière inventée pour la démonstration.
        </p>
      </div>
    </header>

    <section class="px-6 py-16 md:px-12 md:py-24">
      <div class="mx-auto grid max-w-7xl gap-6 md:grid-cols-2">
        {demos.map((demo) => (
          <div class="group flex flex-col overflow-hidden rounded-2xl border border-white/15 transition-colors hover:border-lime">
            <a href={demo.url} target="_blank" rel="noopener" class="block overflow-hidden border-b border-white/10">
              <img
                src={demo.visuel}
                alt={`Aperçu — ${demo.titre}`}
                width="1200"
                height="675"
                loading="lazy"
                class="aspect-video w-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.02]"
              />
            </a>
            <div class="flex flex-1 flex-col p-8 pt-6">
              <div class="text-[11px] uppercase tracking-[0.22em] text-lime">{demo.nature}</div>
              <h2 class="mt-3 text-2xl font-medium leading-snug">{demo.titre}</h2>
              <p class="mt-3 flex-1 text-[15px] leading-relaxed text-white/70">{demo.desc}</p>
              <div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-3">
                <a
                  href={demo.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-3 rounded-full bg-lime px-5 py-3 text-sm font-medium text-black transition-all hover:bg-lime/90"
                >
                  {demo.action} <span>→</span>
                </a>
                {demo.caseUrl && (
                  <a href={demo.caseUrl} class="text-sm text-white/60 underline-offset-4 hover:text-lime hover:underline">
                    Lire l'étude de cas
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="mx-auto mt-12 max-w-7xl text-sm text-white/45">
        Les démos s'ouvrent dans un nouvel onglet. Aucune donnée client réelle n'y figure —
        les livrables complets se partagent en rendez-vous, avec l'accord des clients concernés.
      </p>
    </section>

    <Footer />
  </main>
</BaseLayout>
