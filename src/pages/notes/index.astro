---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/lib/site";

const notes = (await getCollection("notes", ({ data }) => data.published)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const fmt = new Intl.DateTimeFormat("fr-FR", { year: "numeric", month: "long", day: "numeric" });

const title = "Notes — écrits d'analyse | Julien Tridat";
const description =
  "Essais, méthodes et analyses sur l'IA en entreprise, le marketing B2B et la preuve par le faire. Le raisonnement documenté, pas seulement le résultat.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Notes — Julien Tridat",
    description,
    url: `${SITE.url}/notes`,
    author: { "@id": `${SITE.url}/#julien-tridat` },
  },
];
---

<BaseLayout title={title} description={description} canonical={`${SITE.url}/notes`} jsonLd={jsonLd}>
  <main class="bg-background text-foreground">
    <header class="relative border-b border-white/10 px-6 pb-16 pt-36 md:px-12 md:pb-24 md:pt-44">
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background: radial-gradient(700px 400px at 20% 0%, oklch(0.92 0.21 125 / 0.07), transparent 70%);"
      >
      </div>
      <Nav />
      <div class="mx-auto max-w-7xl">
        <Eyebrow>Notes</Eyebrow>
        <h1 class="max-w-4xl text-[clamp(2.5rem,6vw,4.5rem)] font-light leading-[1.02] tracking-[-0.03em]">
          Le raisonnement, <em class="text-lime">documenté.</em>
        </h1>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-white/70">
          Essais, méthodes, analyses. Ce que j'apprends sur le terrain — IA en entreprise,
          marketing B2B, preuve par le faire — écrit pour être utile, pas pour flatter un
          algorithme.
        </p>
      </div>
    </header>

    <section class="px-6 py-16 md:px-12 md:py-24">
      <div class="mx-auto max-w-4xl">
        {notes.map((n) => (
          <a
            href={`/notes/${n.id}`}
            class="group flex flex-col gap-3 border-t border-white/10 py-10 transition-colors first:border-t-0 hover:bg-white/[0.02] md:flex-row md:items-baseline md:gap-10"
          >
            <time datetime={n.data.date.toISOString().slice(0, 10)} class="shrink-0 text-sm text-white/45 md:w-40">
              {fmt.format(n.data.date)}
            </time>
            <div>
              <h2 class="text-2xl font-medium leading-snug transition-colors group-hover:text-lime">
                {n.data.title}
              </h2>
              <p class="mt-3 max-w-2xl leading-relaxed text-white/70">{n.data.pitch}</p>
              <div class="mt-4 inline-flex items-center gap-2 text-sm text-lime">
                Lire la note <span class="transition-transform group-hover:translate-x-0.5">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
