---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Eyebrow from "@/components/Eyebrow.astro";
import CtaButton from "@/components/CtaButton.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/lib/site";

// Les moyens de production, regroupés par ce qu'ils installent chez le client.
// Chaque exemple est testable ou visible ; étiquetage honnête réel/fictif.
const familles = [
  {
    titre: "Assistants IA métier",
    quoi: "Une IA calibrée sur votre métier, vos règles et vos garde-fous — livrée à votre équipe, dans ses outils.",
    exemples: [
      { url: "/demos/skill-icp.html", visuel: "/artefacts/skill-icp.webp", nom: "Analyse de marché (méthode ICP)", nature: "Testable", caseUrl: null },
      { url: "/demos/audit-flash.html", visuel: "/artefacts/audit-flash.webp", nom: "Diagnostic « où mettre l'IA »", nature: "Testable", caseUrl: null },
      { url: "/demos/formation-association.html", visuel: "/artefacts/formation-association.webp", nom: "Assistants clé en main", nature: "Réel, anonymisé", caseUrl: "/realisations/association-benevoles-autonome" },
    ],
    aussi: "Aussi déployés en mission : projets IA réglementaires (santé), assistants « chef de projet » calibrés par compte client.",
  },
  {
    titre: "Systèmes de production de contenu",
    quoi: "Votre charte encodée une fois : visuels, présentations, plannings produits à la demande, conformes à chaque fois.",
    exemples: [
      { url: "/demos/visuels-marque.html", visuel: "/artefacts/visuels-marque.webp", nom: "Générateur de visuels chartés", nature: "Système réel, marque fictive", caseUrl: "/realisations/design-system-franchise-fitness" },
      { url: "/demos/vignettes-linkedin.html", visuel: "/artefacts/vignettes-linkedin.webp", nom: "Vignettes LinkedIn en série", nature: "Système réel, marque fictive", caseUrl: null },
      { url: "/demos/support-groupe-retail.html", visuel: "/artefacts/support-groupe-retail.webp", nom: "Supports de formation chartés", nature: "Réel, anonymisé", caseUrl: "/realisations/formation-groupe-travel-retail" },
    ],
    aussi: "Aussi : générateur de rétroplannings au standard maison, guides d'autonomie, un système de présentation par client.",
  },
  {
    titre: "Documents dynamiques & aide à la décision",
    quoi: "Des tableaux de bord et des restitutions qui racontent vos chiffres et éclairent vos arbitrages — pas des slides mortes.",
    exemples: [
      { url: "/demos/dashboard.html", visuel: "/artefacts/dashboard.webp", nom: "Dashboard narratif", nature: "Démo — données fictives", caseUrl: null },
      { url: "/demos/restitution-audit.html", visuel: "/artefacts/restitution-audit.webp", nom: "Restitution de cartographie IA", nature: "Méthode réelle, données fictives", caseUrl: "/realisations/cartographie-ia-agence" },
      { url: "/demos/etude-marche.html", visuel: "/artefacts/etude-marche.webp", nom: "Étude de marché scorée", nature: "Extrait reconstitué", caseUrl: "/realisations/offre-formation-ia-qualiopi" },
    ],
    aussi: null,
  },
  {
    titre: "Sites, plateformes & back-offices",
    quoi: "Des interfaces complètes et des back-offices qui tournent sans vous. Ce site en est un — statique, souverain, à coût nul.",
    exemples: [
      { url: "/realisations/cette-plateforme", visuel: "/artefacts/plateforme.webp", nom: "Cette plateforme (étude de cas)", nature: "Réel", caseUrl: null },
      { url: "/demos/guide-claude-clickup.html", visuel: "/artefacts/guide-claude-clickup.webp", nom: "Back-office piloté par l'IA", nature: "Réel, anonymisé", caseUrl: "/realisations/transformation-ia-organisme-formation" },
    ],
    aussi: "Aussi : cycle devis/facture/avoir automatisé, chaîne de sourcing M&A, contrôle qualité de livrables — mes propres systèmes.",
  },
];

const title = "Capacités — les moyens de production que je déploie | Julien Tridat";
const description =
  "Assistants IA métier, systèmes de production de contenu, documents décisionnels, sites et back-offices : les moyens de production que j'installe en entreprise.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Capacités — Julien Tridat",
    description,
    url: `${SITE.url}/capacites`,
    author: { "@id": `${SITE.url}/#julien-tridat` },
  },
];
---

<BaseLayout title={title} description={description} canonical={`${SITE.url}/capacites`} jsonLd={jsonLd}>
  <main class="bg-background text-foreground">
    <header class="relative border-b border-white/10 px-6 pb-16 pt-36 md:px-12 md:pb-20 md:pt-44">
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        style="background: radial-gradient(700px 400px at 20% 0%, oklch(0.92 0.21 125 / 0.07), transparent 70%);"
      >
      </div>
      <Nav />
      <div class="mx-auto max-w-7xl">
        <Eyebrow>Moyens de production</Eyebrow>
        <h1 class="max-w-4xl text-[clamp(2.5rem,6vw,4.5rem)] font-light leading-[1.02] tracking-[-0.03em]">
          Ce que je peux <em class="text-lime">installer chez vous.</em>
        </h1>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-white/70">
          Je ne vends pas des livrables, j'installe des moyens de production : des systèmes qui
          dotent votre entreprise d'une capacité qu'elle n'avait pas. En voici l'étendue —{" "}
          <strong class="font-medium text-white">cliquez, la plupart tournent dans votre navigateur.</strong>
        </p>
      </div>
    </header>

    {familles.map((fam) => (
      <section class="border-b border-white/10 px-6 py-14 md:px-12 md:py-20">
        <div class="mx-auto max-w-7xl">
          <h2 class="text-[clamp(1.5rem,3vw,2.2rem)] font-light leading-tight tracking-[-0.02em]">
            {fam.titre}<span class="text-lime">.</span>
          </h2>
          <p class="mt-3 max-w-2xl text-[15px] leading-relaxed text-white/60">{fam.quoi}</p>
          <div class="mt-8 grid gap-5 md:grid-cols-3">
            {fam.exemples.map((ex) => (
              <div class="group flex flex-col overflow-hidden rounded-2xl border border-white/12 bg-white/[0.02] transition-colors hover:border-lime/60">
                <a href={ex.url} target={ex.url.startsWith("/demos") ? "_blank" : undefined} rel="noopener" class="block overflow-hidden border-b border-white/10 bg-[oklch(0.16_0_0)]">
                  <img src={ex.visuel} alt={`Aperçu — ${ex.nom}`} width="800" height="450" loading="lazy" class="aspect-[16/9] w-full object-cover object-top transition-transform duration-300 group-hover:scale-[1.03]" />
                </a>
                <div class="flex flex-1 flex-col p-5">
                  <div class="text-[10px] uppercase tracking-[0.2em] text-lime">{ex.nature}</div>
                  <h3 class="mt-2 text-[15px] font-medium leading-snug">{ex.nom}</h3>
                  <div class="mt-auto flex flex-wrap items-center gap-x-4 gap-y-2 pt-4">
                    <a href={ex.url} target={ex.url.startsWith("/demos") ? "_blank" : undefined} rel="noopener" class="inline-flex items-center gap-2 rounded-full bg-lime px-4 py-2 text-[12.5px] font-medium text-black transition-colors hover:bg-lime/90">
                      {ex.url.startsWith("/demos") ? "Tester" : "Voir"} <span>→</span>
                    </a>
                    {ex.caseUrl && (
                      <a href={ex.caseUrl} class="text-[12.5px] text-white/55 underline-offset-4 hover:text-lime hover:underline">Étude de cas</a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
          {fam.aussi && <p class="mt-6 max-w-3xl text-[13px] leading-relaxed text-white/45">{fam.aussi}</p>}
        </div>
      </section>
    ))}

    <section class="px-6 py-20 md:px-12">
      <div class="mx-auto flex max-w-3xl flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
        <p class="max-w-md text-lg leading-relaxed text-white/75">
          Quel moyen de production manque à votre entreprise ? <em class="text-lime">On le trouve en 30 minutes.</em>
        </p>
        <CtaButton>Réserver un audit</CtaButton>
      </div>
    </section>

    <Footer />
  </main>
</BaseLayout>
