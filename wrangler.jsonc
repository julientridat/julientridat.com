{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "julientridat",
  "main": "worker/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "ai": {
    "binding": "AI"
  }
}
